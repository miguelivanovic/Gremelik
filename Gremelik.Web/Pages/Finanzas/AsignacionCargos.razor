@page "/finanzas/asignacion-cargos"
@using Gremelik.core.Entities
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin")]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid pb-5">
    <h3 class="mb-3">💶 Asignación de Planes y Servicios</h3>
    <p class="text-muted">Genera el estado de cuenta (mensualidades) para el ciclo escolar.</p>

    <div class="row">
        <div class="col-lg-5">
            <div class="card shadow-sm mb-4 border-primary">
                <div class="card-header bg-primary text-white fw-bold">1. Seleccionar Alumno</div>
                <div class="card-body">
                    <div class="input-group mb-3">
                        <input type="text" class="form-control" placeholder="Matrícula o Nombre..." @bind="textoBusqueda" @bind:event="oninput" @onkeyup="@EnterBuscar" />
                        <button class="btn btn-outline-primary" @onclick="BuscarAlumno"><i class="bi bi-search"></i></button>
                    </div>

                    @if (buscando)
                    {
                        <div class="spinner-border spinner-border-sm text-primary"></div>
                    }

                    @if (resultadosBusqueda != null && resultadosBusqueda.Any())
                    {
                        <div class="list-group">
                            @foreach (var a in resultadosBusqueda)
                            {
                                <button class="list-group-item list-group-item-action @(alumnoSeleccionado?.Id == a.Id ? "active" : "")" @onclick="() => SeleccionarAlumno(a)">
                                    <div class="fw-bold">@a.PrimerApellido @a.SegundoApellido @a.Nombre</div>
                                    <small>@a.Matricula</small>
                                </button>
                            }
                        </div>
                    }
                    else if (busco && resultadosBusqueda?.Count == 0)
                    {
                        <div class="alert alert-warning small">No se encontró al alumno.</div>
                    }

                    @if (alumnoSeleccionado != null)
                    {
                        <div class="alert alert-success mt-3 mb-0">
                            <strong><i class="bi bi-person-check-fill"></i> @alumnoSeleccionado.Nombre @alumnoSeleccionado.PrimerApellido</strong><br />
                            <small>Seleccionado correctamente.</small>
                        </div>
                    }
                </div>
            </div>

            @if (alumnoSeleccionado != null)
            {
                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-dark text-white fw-bold">2. Configurar Plan</div>
                    <div class="card-body">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ciclo Escolar</label>
                            <select class="form-select" @onchange="CambiarCiclo">
                                <option value="0">-- Selecciona --</option>
                                @if (ciclos != null)
                                {
                                    foreach (var c in ciclos)
                                    {
                                        <option value="@c.Id">@c.Nombre</option>
                                    }
                                }
                            </select>
                        </div>

                        @if (cicloSeleccionadoId != 0)
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Plan de Colegiatura</label>
                                <select class="form-select border-success" @bind="planSeleccionadoId">
                                    <option value="@Guid.Empty">-- Selecciona Modalidad --</option>
                                    @if (planes != null)
                                    {
                                        foreach (var p in planes)
                                        {
                                            <option value="@p.Id">@p.Nombre (@p.NumeroPagos pagos)</option>
                                        }
                                    }
                                </select>
                                <small class="text-muted">Define si paga a 10, 11 o 12 meses.</small>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Beca Aplicable (Opcional)</label>
                                <select class="form-select" @bind="becaSeleccionadaId">
                                    <option value="">-- Sin Beca --</option>
                                    @if (becas != null)
                                    {
                                        foreach (var b in becas.Where(x => x.AplicaEnColegiatura))
                                        {
                                            <option value="@b.Id">@b.Nombre (@(b.Porcentaje > 0 ? b.Porcentaje + "%" : "$" + b.MontoFijo))</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Servicios Adicionales (Mensuales)</label>
                                <div class="card bg-light border-0">
                                    <div class="card-body py-2">
                                        @if (serviciosAdicionales != null && serviciosAdicionales.Any())
                                        {
                                            @foreach (var s in serviciosAdicionales)
                                            {
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" @onchange="(e) => ToggleServicio(s.Id, e.Value)">
                                                    <label class="form-check-label">
                                                        @s.Nombre <span class="badge bg-secondary">$@s.Monto</span>
                                                    </label>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <small class="text-muted">No hay servicios opcionales (Transporte, etc) configurados.</small>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Cargos Únicos / Obligatorios</label>
                                <div class="card bg-warning bg-opacity-10 border-warning">
                                    <div class="card-body py-2">
                                        @if (conceptosUnicosDisponibles != null && conceptosUnicosDisponibles.Any())
                                        {
                                            @foreach (var c in conceptosUnicosDisponibles)
                                            {
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox"
                                                           checked="@(conceptosUnicosSeleccionados.Contains(c.Id))"
                                                           @onchange="(e) => ToggleConceptoUnico(c.Id, e.Value)">
                                                    <label class="form-check-label">
                                                        @c.Nombre <span class="badge bg-dark">$@c.Monto.ToString("N0")</span>
                                                        @if (c.Obligatorio)
                                                        {
                                                            <span class="badge bg-danger ms-1" style="font-size:0.6em">OBLIGATORIO</span>
                                                        }
                                                    </label>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <small class="text-muted">No hay cargos únicos (Libros/Uniformes) para este grado.</small>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Fecha de Primer Pago</label>
                                <input type="date" class="form-control" @bind="fechaInicioCobro" />
                                <small class="text-muted">
                                    <i class="bi bi-info-circle"></i> Si el alumno entra tarde (ej: Noviembre), selecciona la fecha de ingreso. El sistema omitirá los meses anteriores.
                                </small>
                            </div>

                            <button class="btn btn-success w-100 py-2 fw-bold shadow" @onclick="GenerarCargos" disabled="@generando">
                                @if (generando)
                                {
                                    <span class="spinner-border spinner-border-sm"></span>
                                    <span class="ms-2">Generando...</span>
                                }
                                else
                                {
                                    <span><i class="bi bi-cash-stack"></i> GENERAR ESTADO DE CUENTA</span>
                                }
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-7">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-white fw-bold">
                    📋 Estado de Cuenta Actual
                </div>
                <div class="card-body">
                    @if (alumnoSeleccionado == null)
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-arrow-left-circle display-4"></i>
                            <p class="mt-3">Selecciona un alumno para ver sus cargos.</p>
                        </div>
                    }
                    else if (cargosExistentes == null)
                    {
                        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
                    }
                    else if (!cargosExistentes.Any())
                    {
                        <div class="alert alert-info text-center">
                            Este alumno no tiene cargos generados para el ciclo seleccionado.<br />
                            <strong>¡Configura el plan a la izquierda y genera la deuda!</strong>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover table-sm">
                                <thead class="table-light">
                                    <tr>
                                        <th>Concepto</th>
                                        <th>Vencimiento</th>
                                        <th class="text-end">Monto</th>
                                        <th class="text-end">Desc.</th>
                                        <th class="text-end">Total</th>
                                        <th>Estatus</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var c in cargosExistentes)
                                    {
                                        <tr>
                                            <td>@c.ConceptoNombre <span class="badge bg-light text-dark border">@c.NumeroDePago</span></td>
                                            <td>@c.FechaVencimiento.ToShortDateString()</td>
                                            <td class="text-end">$@c.MontoBase.ToString("N0")</td>
                                            <td class="text-end text-danger">-$@c.DescuentoBeca.ToString("N0")</td>
                                            <td class="text-end fw-bold">$@((c.MontoBase - c.DescuentoBeca + c.RecargosAcumulados).ToString("N0"))</td>
                                            <td>
                                                @if (c.Estado == "PAGADO")
                                                {
                                                    <span class="badge bg-success">PAGADO</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-warning text-dark">PENDIENTE</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot class="table-light fw-bold">
                                    <tr>
                                        <td colspan="4" class="text-end">TOTAL ANUAL A PAGAR:</td>
                                        <td class="text-end text-primary fs-5">
                                            $@cargosExistentes.Sum(x => x.MontoBase - x.DescuentoBeca + x.RecargosAcumulados).ToString("N0")
                                        </td>
                                        <td></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    // ESTADO BÚSQUEDA
    string textoBusqueda = "";
    bool buscando = false, busco = false;
    List<Alumno>? resultadosBusqueda;
    Alumno? alumnoSeleccionado;

    List<ConceptoPago>? conceptosUnicosDisponibles;
    List<Guid> conceptosUnicosSeleccionados = new();

    DateTime fechaInicioCobro = DateTime.Today; // Por defecto hoy

    // ESTADO CONFIGURACIÓN
    List<CicloEscolar>? ciclos;
    int cicloSeleccionadoId = 0;

    List<PlanPago>? planes;
    Guid planSeleccionadoId;

    List<Beca>? becas;
    Guid? becaSeleccionadaId; // Nullable para "Sin Beca"

    List<ConceptoPago>? serviciosAdicionales; // Transporte, etc.
    List<Guid> serviciosSeleccionadosIds = new();

    // ESTADO VISTA PREVIA
    List<CuentaPorCobrar>? cargosExistentes;
    bool generando = false;

    // ... tus otras variables ...
    int? gradoAlumnoId = 0; // <--- Aquí guardaremos en qué grado va

    protected override async Task OnInitializedAsync()
    {
        var todos = await Http.GetFromJsonAsync<List<CicloEscolar>>("api/Ciclos");
        if (todos != null) ciclos = todos.OrderByDescending(c => c.FechaInicio).ToList();
    }

    // --- BÚSQUEDA ---
    async Task BuscarAlumno()
    {
        if (string.IsNullOrWhiteSpace(textoBusqueda)) return;
        buscando = true; busco = true; resultadosBusqueda = null; alumnoSeleccionado = null;
        resultadosBusqueda = await Http.GetFromJsonAsync<List<Alumno>>($"api/Alumnos/buscar/{textoBusqueda}");
        buscando = false;
    }
    async Task EnterBuscar(KeyboardEventArgs e) { if (e.Key == "Enter") await BuscarAlumno(); }

    async Task SeleccionarAlumno(Alumno a)
    {
        alumnoSeleccionado = a;
        resultadosBusqueda = null;
        textoBusqueda = "";
        cargosExistentes = null;

        // --- NUEVO: OBTENER EL GRADO ACTUAL DEL ALUMNO ---
        gradoAlumnoId = 0; // Reset
        try
        {
            // Usamos el endpoint que ya tenías para reinscripción
            // Necesitas definir esta clase DTO pequeña abajo o usar dynamic
            var info = await Http.GetFromJsonAsync<HistorialAcademicoDto>($"api/Inscripciones/ultima/{a.Id}");
            if (info != null)
            {
                gradoAlumnoId = info.GradoId;
            }
        }
        catch
        {
            // Si falla o no tiene inscripción, asumimos que no tiene grado asignado aún
        }
        // -------------------------------------------------

        if (cicloSeleccionadoId != 0) await CargarCargosExistentes();
    }

    async Task CambiarCiclo(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            cicloSeleccionadoId = id;
            planes = await Http.GetFromJsonAsync<List<PlanPago>>($"api/Finanzas/planes/{id}");
            becas = await Http.GetFromJsonAsync<List<Beca>>($"api/Becas/ciclo/{id}");

            var todos = await Http.GetFromJsonAsync<List<ConceptoPago>>($"api/Finanzas/conceptos/{id}");

            if (todos != null)
            {
                serviciosAdicionales = todos.Where(c => c.Frecuencia == FrecuenciaPago.Mensual && !c.Obligatorio).ToList();

                var unicosRaw = todos.Where(c => c.Frecuencia == FrecuenciaPago.PagoUnico).ToList();

                conceptosUnicosDisponibles = new List<ConceptoPago>();
                conceptosUnicosSeleccionados.Clear();

                // --- AQUÍ VA LA LÓGICA QUE PREGUNTASTE ---
                foreach (var c in unicosRaw)
                {
                    // Si el concepto NO tiene grado especifico (es null) -> ACEPTAR (Es para todos)
                    // O
                    // Si el concepto TIENE grado Y coincide con el del alumno -> ACEPTAR
                    if (c.GradoId == null || c.GradoId == 0 || c.GradoId == gradoAlumnoId)
                    {
                        conceptosUnicosDisponibles.Add(c);

                        // Si es obligatorio, pre-seleccionar
                        if (c.Obligatorio) conceptosUnicosSeleccionados.Add(c.Id);
                    }
                }
                // -----------------------------------------
            }

            if (alumnoSeleccionado != null) await CargarCargosExistentes();
        }
    }

    void ToggleConceptoUnico(Guid id, object? checkedValue)
    {
        bool isChecked = (bool)(checkedValue ?? false);
        if (isChecked) { if (!conceptosUnicosSeleccionados.Contains(id)) conceptosUnicosSeleccionados.Add(id); }
        else { conceptosUnicosSeleccionados.Remove(id); }
    }

    void ToggleServicio(Guid id, object? checkedValue)
    {
        bool isChecked = (bool)(checkedValue ?? false);
        if (isChecked) serviciosSeleccionadosIds.Add(id);
        else serviciosSeleccionadosIds.Remove(id);
    }

    async Task CargarCargosExistentes()
    {
        cargosExistentes = await Http.GetFromJsonAsync<List<CuentaPorCobrar>>($"api/Cuentas/alumno/{alumnoSeleccionado!.Id}/ciclo/{cicloSeleccionadoId}");
    }

    // --- GENERACIÓN ---
    async Task GenerarCargos()
    {
        if (planSeleccionadoId == Guid.Empty) { await JS.InvokeVoidAsync("alert", "Selecciona un Plan de Colegiatura."); return; }

        // --- NUEVA VALIDACIÓN INTELIGENTE ---
        // Revisamos si el alumno tiene cargos en este ciclo que NO sean inscripciones
        bool tieneColegiaturasOCargos = cargosExistentes != null &&
             cargosExistentes.Any(c => !c.ConceptoNombre.ToLower().Contains("inscripci"));

        if (tieneColegiaturasOCargos)
        {
            if (!await JS.InvokeAsync<bool>("confirm", "⚠️ ESTE ALUMNO YA TIENE COLEGIATURAS O SERVICIOS GENERADOS.\n\nGenerar de nuevo podría duplicar deudas si no cancelaste las anteriores. ¿Seguro que deseas continuar?"))
                return;
        }
        // ------------------------------------

        generando = true;

        var dto = new
        {
            AlumnoId = alumnoSeleccionado!.Id,
            CicloId = cicloSeleccionadoId,
            PlanPagoId = planSeleccionadoId,
            BecaId = becaSeleccionadaId == Guid.Empty ? null : becaSeleccionadaId,
            ServiciosAdicionalesIds = serviciosSeleccionadosIds,
            ConceptosUnicosIds = conceptosUnicosSeleccionados, // <--- ENVIAMOS LOS LIBROS
            FechaInicioCobro = fechaInicioCobro
        };

        var res = await Http.PostAsJsonAsync("api/Cuentas/generar", dto);

        if (res.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "✅ ¡Estado de Cuenta Generado Exitosamente!");
            await CargarCargosExistentes();
            // Limpiar selección para evitar doble click
            serviciosSeleccionadosIds.Clear();
        }
        else
        {
            var msg = await res.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", "❌ Error: " + msg);
        }
        generando = false;
    }

    public class HistorialAcademicoDto
    {
        public int GradoId { get; set; }
        // ... otros campos que no usaremos aquí ...
    }
}