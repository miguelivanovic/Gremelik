@page "/finanzas/caja"
@using Gremelik.core.Entities
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin, Coordinador, Cajero")]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid pb-5">
    <div class="row">
        <div class="col-lg-8">
            <div class="card shadow-sm mb-3">
                <div class="card-body bg-light">
                    <h5 class="card-title text-primary"><i class="bi bi-person-bounding-box"></i> Buscar Alumno</h5>
                    <div class="input-group">
                        <input type="text" class="form-control form-control-lg" placeholder="Matrícula o Nombre..." @bind="textoBusqueda" @onkeyup="@EnterBuscar" />
                        <button class="btn btn-primary" @onclick="BuscarAlumno"><i class="bi bi-search"></i></button>
                    </div>

                    @if (resultadosBusqueda != null && resultadosBusqueda.Any())
                    {
                        <div class="list-group mt-2 shadow" style="position: absolute; z-index: 1000; width: 95%;">
                            @foreach (var a in resultadosBusqueda)
                            {
                                <button class="list-group-item list-group-item-action" @onclick="() => SeleccionarAlumno(a)">
                                    <strong>@a.PrimerApellido @a.SegundoApellido @a.Nombre</strong> <small class="text-muted">(@a.Matricula)</small>
                                </button>
                            }
                        </div>
                    }
                </div>
            </div>

            @if (alumnoSeleccionado != null)
            {
                <div class="card shadow-sm border-primary mb-3">
                    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                        <span class="fw-bold">@alumnoSeleccionado.Nombre @alumnoSeleccionado.PrimerApellido</span>
                        <small>@alumnoSeleccionado.Matricula</small>
                    </div>
                    <div class="card-body p-0">
                        <div class="p-3 bg-light border-bottom">
                            <label class="small fw-bold">Ver deudas del ciclo:</label>
                            <select class="form-select form-select-sm w-auto d-inline-block ms-2" value="@cicloId" @onchange="CambiarCiclo">
                                <option value="0">-- Selecciona --</option>
                                @if (ciclos != null)
                                {
                                    foreach (var c in ciclos)
                                    {
                                        <option value="@c.Id">@c.Nombre</option>
                                    }
                                }
                            </select>
                        </div>

                        @if (deudas == null)
                        {
                            <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
                        }
                        else if (!deudas.Any())
                        {
                            <div class="alert alert-success m-3">🎉 ¡Este alumno no tiene adeudos pendientes en este ciclo!</div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0 align-middle">
                                    <thead class="table-light">
                                        <tr>
                                            <th style="width: 40px;"></th>
                                            <th>Concepto</th>
                                            <th>Vence</th>
                                            <th class="text-end">Base / Recargo</th>
                                            <th class="text-end">Beca</th>
                                            <th class="text-end">Total a Pagar</th>
                                            <th class="text-center">Auditoría</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var d in deudas)
                                        {
                                            <tr class="@(d.Seleccionado ? "table-active" : "") @(d.EsRecargoVirtual ? "table-danger" : "")">
                                                <td class="text-center" @onclick="() => ToggleSeleccion(d)" style="cursor: pointer;">
                                                    <input type="checkbox" class="form-check-input" checked="@d.Seleccionado" readonly />
                                                </td>
                                                <td @onclick="() => ToggleSeleccion(d)" style="cursor: pointer;">
                                                    @if (d.EsRecargoVirtual)
                                                    {
                                                        <i class="bi bi-exclamation-triangle-fill text-danger me-1"></i>
                                                    }
                                                    @d.ConceptoNombre
                                                    @if (d.NumeroDePago > 0)
                                                    {
                                                        <span class="badge bg-light text-dark border ms-1">@d.NumeroDePago</span>
                                                    }
                                                    @if (d.Estado == "PARCIAL")
                                                    {
                                                        <span class="badge bg-warning text-dark">PARCIAL</span>
                                                    }
                                                </td>
                                                <td>
                                                    <span class="@(d.FechaVencimiento < DateTime.Today && !d.EsRecargoVirtual ? "text-danger fw-bold" : "")">@d.FechaVencimiento.ToShortDateString()</span>
                                                </td>

                                                <td class="text-end">
                                                    @if (d.EsRecargoVirtual && d.ExcepcionRecargoActivado)
                                                    {
                                                        <span class="text-muted text-decoration-line-through">$@d.MontoBase.ToString("N2")</span>
                                                    }
                                                    else
                                                    {
                                                        <span>$@d.MontoBase.ToString("N2")</span>
                                                    }
                                                </td>

                                                <td class="text-end @(d.BecaPerdidaPorAtraso && !d.ExcepcionBecaActivada ? "text-danger text-decoration-line-through" : "text-success")">
                                                    @if (!d.EsRecargoVirtual && d.DescuentoBecaOriginal > 0)
                                                    {
                                                        <span>-$@d.DescuentoFinalCalculado.ToString("N2")</span>
                                                    }
                                                </td>

                                                <td class="text-end fw-bold fs-6 @(d.EsRecargoVirtual ? "text-danger" : "text-primary")">$@d.SaldoActual.ToString("N2")</td>

                                                <td class="text-center">
                                                    @if (d.BecaPerdidaPorAtraso)
                                                    {
                                                        <button class="btn btn-sm btn-outline-warning" title="Restaurar Beca" @onclick="() => AbrirModalExcepcion(d, true)">
                                                            <i class="bi bi-shield-lock"></i> Beca
                                                        </button>
                                                    }
                                                    @if (d.EsRecargoVirtual)
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger" title="Perdonar Recargo" @onclick="() => AbrirModalExcepcion(d, false)">
                                                            <i class="bi bi-shield-lock"></i> Perdón
                                                        </button>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="col-lg-4">
            <div class="card shadow h-100 border-success">
                <div class="card-header bg-success text-white text-center py-3">
                    <h4 class="mb-0"><i class="bi bi-cart4"></i> CAJA</h4>
                </div>
                <div class="card-body d-flex flex-column">

                    <div class="flex-grow-1 overflow-auto mb-3" style="max-height: 250px;">
                        <h6 class="text-muted border-bottom pb-2">Conceptos Seleccionados:</h6>
                        @if (deudas != null && deudas.Any(x => x.Seleccionado && x.SaldoActual > 0))
                        {
                            <ul class="list-group list-group-flush small">
                                @foreach (var sel in deudas.Where(x => x.Seleccionado && x.SaldoActual > 0))
                                {
                                    <li class="list-group-item d-flex justify-content-between px-0">
                                        <span>@sel.ConceptoNombre</span>
                                        <span class="fw-bold">$@sel.SaldoActual.ToString("N2")</span>
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="text-muted text-center mt-4">Selecciona conceptos de la izquierda.</p>
                        }
                    </div>

                    <div class="bg-light p-3 rounded mb-3 border">
                        <div class="d-flex justify-content-between mb-3 border-bottom pb-2">
                            <span class="fs-5">Total a Pagar:</span>
                            <span class="fs-4 fw-bold text-dark">$@TotalSeleccionado.ToString("N2")</span>
                        </div>

                        <div class="mb-3">
                            <label class="small fw-bold text-success">Método de Pago</label>
                            <select class="form-select border-success fw-bold" @bind="metodoPago">
                                <option value="1">Efectivo</option>
                                <option value="2">Tarjeta Débito</option>
                                <option value="3">Tarjeta Crédito</option>
                                <option value="4">Transferencia</option>
                                <option value="5">Cheque</option>
                            </select>
                        </div>

                        @if (metodoPago == 2 || metodoPago == 3)
                        {
                            <div class="bg-white p-2 border rounded mb-3 shadow-sm">
                                <label class="small fw-bold text-primary mb-1"><i class="bi bi-credit-card"></i> Datos Bancarios (Obligatorio)</label>
                                <input type="text" class="form-control form-control-sm mb-2" placeholder="Banco (Ej. BBVA)" @bind="bancoTarjeta" />
                                <div class="d-flex gap-2">
                                    <input type="text" class="form-control form-control-sm" placeholder="Terminación (4 dígitos)" maxlength="4" @bind="terminacionTarjeta" />
                                    <input type="text" class="form-control form-control-sm" placeholder="No. Autorización" @bind="autorizacionTarjeta" />
                                </div>
                            </div>
                        }

                        <div class="mb-2">
                            <label class="small fw-bold text-success">Dinero Recibido ($)</label>
                            <input type="text" inputmode="decimal" class="form-control form-control-lg text-end fw-bold text-success border-success"
                                   placeholder="0.00"
                                   @bind="dineroRecibido" />
                        </div>
                    </div>

                    <div class="mb-2">
                        <textarea class="form-control form-control-sm" placeholder="Notas del cajero (Opcional)" @bind="comentarios"></textarea>
                    </div>

                    <div class="mb-3 p-3 border rounded @(requiereFactura ? "bg-primary bg-opacity-10 border-primary" : "bg-light")">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="checkFactura"
                                   @bind="requiereFactura"
                                   disabled="@(!HayConceptosFacturables)">
                            <label class="form-check-label fw-bold @(requiereFactura ? "text-primary" : "text-muted")" for="checkFactura">
                                <i class="bi bi-receipt"></i> Requiere Factura (CFDI)
                            </label>
                        </div>

                        @if (!HayConceptosFacturables && TotalSeleccionado > 0)
                        {
                            <small class="text-warning d-block mb-2">
                                <i class="bi bi-info-circle"></i> Los conceptos seleccionados no son facturables.
                            </small>
                        }

                        @if (requiereFactura)
                        {
                            <label class="small fw-bold">Seleccionar Datos Fiscales (Tutor)</label>
                            <select class="form-select form-select-sm border-primary" @bind="tutorSeleccionadoId">
                                <option value="">-- Selecciona a quién facturar --</option>
                                @if (tutoresAlumno != null)
                                {
                                    @foreach (var t in tutoresAlumno)
                                    {
                                        <option value="@t.Id">@t.Nombre @t.PrimerApellido - RFC: @(string.IsNullOrEmpty(t.RFC) ? "SIN RFC" : t.RFC)</option>
                                    }
                                }
                            </select>
                        }
                    </div>

                    <button class="btn btn-success w-100 py-3 fw-bold fs-5 shadow"
                            @onclick="ProcesarCobro"
                            disabled="@(!PuedeCobrar)">
                        <i class="bi bi-check-circle-fill"></i> PROCESAR COBRO
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@if (mostrarModalExcepcion && deudaExcepcion != null)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.6)">
        <div class="modal-dialog">
            <div class="modal-content border-warning">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title fw-bold"><i class="bi bi-shield-lock"></i> Excepción de Caja</h5>
                    <button class="btn-close" @onclick="()=>mostrarModalExcepcion=false"></button>
                </div>
                <div class="modal-body">
                    <p class="small text-muted mb-3">Estás a punto de alterar los cobros automáticos del sistema. Esto quedará registrado en auditoría.</p>

                    @if (modoExcepcionBeca)
                    {
                        <div class="form-check form-switch mb-3 p-2 border rounded bg-light">
                            <input class="form-check-input ms-2 me-2" type="checkbox" @bind="deudaExcepcion.ExcepcionBecaActivada">
                            <label class="form-check-label fw-bold">Restaurar Beca Perdida ($@deudaExcepcion.DescuentoBecaOriginal.ToString("N2"))</label>
                        </div>
                    }
                    else
                    {
                        <div class="form-check form-switch mb-3 p-2 border rounded bg-light">
                            <input class="form-check-input ms-2 me-2" type="checkbox" @bind="deudaExcepcion.ExcepcionRecargoActivado">
                            <label class="form-check-label fw-bold">Perdonar Recargo Visual ($@deudaExcepcion.MontoBase.ToString("N2"))</label>
                        </div>
                    }

                    <label class="fw-bold">Motivo de la Excepción *</label>
                    <textarea class="form-control border-warning" rows="2" @bind="deudaExcepcion.MotivoExcepcion" placeholder="Ej: Autorizado por Dirección..."></textarea>
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-warning fw-bold w-100" @onclick="()=>mostrarModalExcepcion=false">Aplicar Cambios</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    class DeudaUI
    {
        public Guid CuentaPorCobrarId { get; set; }
        public string ConceptoNombre { get; set; } = "";
        public int NumeroDePago { get; set; }
        public DateTime FechaVencimiento { get; set; }
        public decimal MontoBase { get; set; }
        public decimal DescuentoBecaOriginal { get; set; }
        public decimal DescuentoBecaAplicado { get; set; }
        public decimal TotalPagado { get; set; }
        public string Estado { get; set; } = "";
        public bool EsFacturable { get; set; }
        public bool BecaPerdidaPorAtraso { get; set; }

        public bool EsRecargoVirtual { get; set; }
        public Guid? DeudaOriginalId { get; set; }
        public Guid? ConceptoPagoId { get; set; }

        public bool Seleccionado { get; set; }
        public bool ExcepcionBecaActivada { get; set; }
        public bool ExcepcionRecargoActivado { get; set; }
        public string MotivoExcepcion { get; set; } = "";

        public decimal DescuentoFinalCalculado => ExcepcionBecaActivada ? DescuentoBecaOriginal : DescuentoBecaAplicado;

        public decimal SaldoActual => EsRecargoVirtual
            ? (ExcepcionRecargoActivado ? 0 : MontoBase)
            : (MontoBase - DescuentoFinalCalculado - TotalPagado);
    }

    class RespuestaCobro
    {
        public string Mensaje { get; set; } = "";
        public int Folio { get; set; }
        public Guid PagoId { get; set; }
    }

    string textoBusqueda = "";
    List<Alumno>? resultadosBusqueda;
    Alumno? alumnoSeleccionado;
    List<CicloEscolar>? ciclos;
    int cicloId = 0;
    List<DeudaUI>? deudas;

    int metodoPago = 1;
    decimal? dineroRecibido;
    string comentarios = "";
    string bancoTarjeta = ""; string terminacionTarjeta = ""; string autorizacionTarjeta = "";

    decimal TotalSeleccionado => deudas?.Where(x => x.Seleccionado).Sum(x => x.SaldoActual) ?? 0;
    bool HayConceptosFacturables => deudas?.Any(x => x.Seleccionado && x.EsFacturable && x.SaldoActual > 0) ?? false;
    bool PuedeCobrar => TotalSeleccionado > 0 && dineroRecibido.HasValue && dineroRecibido.Value > 0 && dineroRecibido.Value <= TotalSeleccionado;

    bool requiereFactura = false;
    List<Tutor>? tutoresAlumno;
    Guid? tutorSeleccionadoId;

    bool mostrarModalExcepcion = false;
    bool modoExcepcionBeca = true;
    DeudaUI? deudaExcepcion;

    [SupplyParameterFromQuery(Name = "alumnoId")]
    public Guid? ParamAlumnoId { get; set; }

    [SupplyParameterFromQuery(Name = "conceptos")]
    public string? ParamConceptosSeleccionados { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var todos = await Http.GetFromJsonAsync<List<CicloEscolar>>("api/Ciclos");
        if (todos != null)
        {
            ciclos = todos.OrderByDescending(c => c.FechaInicio).ToList();
            var cicloActual = ciclos.FirstOrDefault(c => c.Estatus == EstatusCiclo.Actual);
            cicloId = cicloActual != null ? cicloActual.Id : (ciclos.Any() ? ciclos.First().Id : 0);
        }
        if (ParamAlumnoId.HasValue)
        {
            // Omitimos la búsqueda manual y buscamos directo al alumno
            textoBusqueda = ParamAlumnoId.Value.ToString();
            var alumnoEncontrado = await Http.GetFromJsonAsync<Alumno>($"api/Alumnos/{ParamAlumnoId.Value}");

            if (alumnoEncontrado != null)
            {
                await SeleccionarAlumno(alumnoEncontrado);

                // Esperamos a que la caja cargue las deudas, y luego "Palomeamos" las que nos mandaron
                if (!string.IsNullOrEmpty(ParamConceptosSeleccionados) && deudas != null)
                {
                    // 1. Obtenemos los IDs que vienen de la pantalla de Morosos
                    var idsRecibidos = ParamConceptosSeleccionados.Split(',').Select(Guid.Parse).ToList();

                    foreach (var d in deudas)
                    {
                        // 2. Si el ID de la deuda viene en la lista, la seleccionamos
                        if (idsRecibidos.Contains(d.CuentaPorCobrarId))
                        {
                            d.Seleccionado = true;
                        }

                        // 3. ¡LA CLAVE!: Si esta fila es un recargo, y el ID de su "deuda padre"
                        // viene en la lista de seleccionados, márcalo también automáticamente.
                        if (d.EsRecargoVirtual && d.DeudaOriginalId.HasValue)
                        {
                            if (idsRecibidos.Contains(d.DeudaOriginalId.Value))
                            {
                                d.Seleccionado = true;
                            }
                        }
                    }

                    // Aquí puedes llamar a tu método de "CalcularTotal" o "SumarTicket"
                    // para que el botón de cobrar ya aparezca con el monto correcto.
                }
            }
        }
    }

    async Task BuscarAlumno()
    {
        if (string.IsNullOrWhiteSpace(textoBusqueda)) return;
        resultadosBusqueda = await Http.GetFromJsonAsync<List<Alumno>>($"api/Alumnos/buscar/{textoBusqueda}");
    }

    async Task EnterBuscar(KeyboardEventArgs e) { if (e.Key == "Enter") await BuscarAlumno(); }

    async Task SeleccionarAlumno(Alumno a)
    {
        alumnoSeleccionado = a;
        resultadosBusqueda = null; textoBusqueda = "";
        requiereFactura = false; tutorSeleccionadoId = null;

        var respuestaTutores = await Http.GetFromJsonAsync<List<Tutor>>($"api/Caja/tutores/{a.Id}");
        tutoresAlumno = respuestaTutores ?? new List<Tutor>();

        var tutorConRFC = tutoresAlumno.FirstOrDefault(t => !string.IsNullOrWhiteSpace(t.RFC));
        if (tutorConRFC != null) tutorSeleccionadoId = tutorConRFC.Id;
        else if (tutoresAlumno.Any()) tutorSeleccionadoId = tutoresAlumno.First().Id;

        await CargarDeudas();
    }

    async Task CambiarCiclo(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            cicloId = id;
            await CargarDeudas();
        }
    }

    async Task CargarDeudas()
    {
        if (alumnoSeleccionado == null || cicloId == 0) return;
        deudas = await Http.GetFromJsonAsync<List<DeudaUI>>($"api/Caja/deudas/{alumnoSeleccionado.Id}/ciclo/{cicloId}");
        dineroRecibido = null;
    }

    void ToggleSeleccion(DeudaUI d)
    {
        d.Seleccionado = !d.Seleccionado;

        if (deudas != null)
        {
            if (!d.EsRecargoVirtual && d.Seleccionado)
            {
                var recargo = deudas.FirstOrDefault(x => x.EsRecargoVirtual && x.DeudaOriginalId == d.CuentaPorCobrarId);
                if (recargo != null) recargo.Seleccionado = true;
            }
            else if (!d.EsRecargoVirtual && !d.Seleccionado)
            {
                var recargo = deudas.FirstOrDefault(x => x.EsRecargoVirtual && x.DeudaOriginalId == d.CuentaPorCobrarId);
                if (recargo != null) recargo.Seleccionado = false;
            }
            else if (d.EsRecargoVirtual && !d.Seleccionado)
            {
                var baseDeuda = deudas.FirstOrDefault(x => !x.EsRecargoVirtual && x.CuentaPorCobrarId == d.DeudaOriginalId);
                if (baseDeuda != null) baseDeuda.Seleccionado = false;
            }
            else if (d.EsRecargoVirtual && d.Seleccionado)
            {
                var baseDeuda = deudas.FirstOrDefault(x => !x.EsRecargoVirtual && x.CuentaPorCobrarId == d.DeudaOriginalId);
                if (baseDeuda != null) baseDeuda.Seleccionado = true;
            }
        }

        //if (dineroRecibido == null || dineroRecibido == 0) dineroRecibido = TotalSeleccionado;

        if (!HayConceptosFacturables) requiereFactura = false;
    }

    void AbrirModalExcepcion(DeudaUI d, bool esParaBeca)
    {
        deudaExcepcion = d;
        modoExcepcionBeca = esParaBeca;
        mostrarModalExcepcion = true;
    }

    async Task ProcesarCobro()
    {
        if (!dineroRecibido.HasValue) return;

        if (metodoPago == 2 || metodoPago == 3)
        {
            if (string.IsNullOrWhiteSpace(bancoTarjeta) || string.IsNullOrWhiteSpace(terminacionTarjeta) || string.IsNullOrWhiteSpace(autorizacionTarjeta))
            {
                await JS.InvokeVoidAsync("alert", "⚠️ Debes llenar Banco, Terminación y Autorización para pagos con tarjeta.");
                return;
            }
        }

        var excepcionesActivas = deudas!.Where(x => x.Seleccionado && (x.ExcepcionBecaActivada || x.ExcepcionRecargoActivado)).ToList();
        if (excepcionesActivas.Any(x => string.IsNullOrWhiteSpace(x.MotivoExcepcion)))
        {
            await JS.InvokeVoidAsync("alert", "⚠️ Hay conceptos con recargos o becas perdonados sin un motivo. Por favor, escribe la razón en el ícono del candado.");
            return;
        }

        if (!await JS.InvokeAsync<bool>("confirm", $"¿Procesar cobro por ${dineroRecibido.Value:N2}?")) return;

        var itemsAPagar = deudas!.Where(x => x.Seleccionado && x.SaldoActual > 0 || (x.EsRecargoVirtual && x.ExcepcionRecargoActivado && x.Seleccionado))
             // NUEVO: ESTA LÍNEA OBLIGA A COBRAR RECARGOS PRIMERO SIN IMPORTAR CÓMO CLICKEÓ LA CAJERA
             .OrderByDescending(x => x.EsRecargoVirtual || x.ConceptoNombre.StartsWith("Recargo"))
             .Select(x => new
             {
                 CuentaPorCobrarId = x.CuentaPorCobrarId,
                 MontoAPagar = x.SaldoActual,
                 DescuentoBecaFinalCalculado = x.DescuentoFinalCalculado,
                 EsRecargoVirtual = x.EsRecargoVirtual,
                 DeudaOriginalId = x.DeudaOriginalId,
                 ConceptoPagoId = x.ConceptoPagoId,
                 ConceptoNombreVirtual = x.ConceptoNombre,
                 ExcepcionBecaActivada = x.ExcepcionBecaActivada,
                 ExcepcionRecargoActivado = x.ExcepcionRecargoActivado,
                 MotivoExcepcion = x.MotivoExcepcion
             }).ToList();

        var pagoDto = new
        {
            AlumnoId = alumnoSeleccionado!.Id,
            CicloId = cicloId,
            MetodoPago = metodoPago,
            DineroRecibido = dineroRecibido.Value,
            Comentarios = comentarios,
            ConceptosAPagar = itemsAPagar,
            RequiereFactura = requiereFactura,
            TutorId = tutorSeleccionadoId,
            Banco = metodoPago == 2 || metodoPago == 3 ? bancoTarjeta : null,
            TerminacionTarjeta = metodoPago == 2 || metodoPago == 3 ? terminacionTarjeta : null,
            Autorizacion = metodoPago == 2 || metodoPago == 3 ? autorizacionTarjeta : null
        };

        var response = await Http.PostAsJsonAsync("api/Caja/cobrar", pagoDto);

        if (response.IsSuccessStatusCode)
        {
            var resultado = await response.Content.ReadFromJsonAsync<RespuestaCobro>();

            await JS.InvokeVoidAsync("alert", $"✅ ¡Cobro Exitoso! (Folio: {resultado!.Folio})");

            var urlPdf = $"{Http.BaseAddress}api/Reportes/recibo/{resultado.PagoId}";
            await JS.InvokeVoidAsync("window.open", urlPdf, "_blank");

            bancoTarjeta = ""; terminacionTarjeta = ""; autorizacionTarjeta = ""; comentarios = ""; dineroRecibido = null;
            await CargarDeudas();
        }
        else
        {
            var msg = await response.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", "❌ Error: " + msg);
        }
    }
}