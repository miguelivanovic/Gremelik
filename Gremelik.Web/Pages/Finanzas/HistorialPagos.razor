@page "/finanzas/historial-pagos"
@using Gremelik.core.DTOs
@using Gremelik.core.Entities
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin, Coordinador, Cajero")]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-clock-history text-primary"></i> Historial General de Pagos</h3>
    </div>

    <div class="card shadow-sm border-0 bg-light mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label class="fw-bold text-muted small">Desde:</label>
                    <input type="date" class="form-control" @bind="fechaInicio" />
                </div>
                <div class="col-md-2">
                    <label class="fw-bold text-muted small">Hasta:</label>
                    <input type="date" class="form-control" @bind="fechaFin" />
                </div>

                <div class="col-md-2">
                    <label class="fw-bold text-muted small">Plantel:</label>
                    <select class="form-select" @bind="plantelId" @bind:after="CargarNiveles">
                        <option value="">TODOS</option>
                        @if (planteles != null)
                        {
                            @foreach (var p in planteles)
                            {
                                <option value="@p.Id">@p.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="fw-bold text-muted small">Nivel:</label>
                    <select class="form-select" @bind="nivelId" @bind:after="CargarGrados" disabled="@(niveles == null)">
                        <option value="">TODOS</option>
                        @if (niveles != null)
                        {
                            @foreach (var n in niveles)
                            {
                                <option value="@n.Id">@n.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="fw-bold text-muted small">Grado:</label>
                    <select class="form-select" @bind="gradoId" @bind:after="CargarGrupos" disabled="@(grados == null)">
                        <option value="">TODOS</option>
                        @if (grados != null)
                        {
                            @foreach (var g in grados)
                            {
                                <option value="@g.Id">@g.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="fw-bold text-muted small">Ciclo Escolar:</label>
                    <select class="form-select border-primary fw-bold" @bind="cicloFiltroId" @bind:after="CargarGrupos">
                        <option value="0">-- Obligatorio --</option>
                        @if (ciclos != null)
                        {
                            @foreach (var c in ciclos)
                            {
                                <option value="@c.Id">@c.Nombre</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2 mt-3">
                    <label class="fw-bold text-muted small">Grupo:</label>
                    <select class="form-select" @bind="grupoId" disabled="@(grupos == null)">
                        <option value="">TODOS</option>
                        @if (grupos != null)
                        {
                            @foreach (var gr in grupos)
                            {
                                <option value="@gr.Id">@gr.Nombre - @gr.Turno</option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-8 mt-3">
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                        <input type="text" class="form-control" placeholder="Buscar por Folio, Matrícula o Nombre del Alumno..."
                               @bind="textoBusqueda" @onkeyup="EnterBuscar" />
                    </div>
                </div>

                <div class="col-md-2 mt-3">
                    <button class="btn btn-primary w-100 fw-bold shadow-sm" @onclick="BuscarPagos">
                        <i class="bi bi-funnel-fill"></i> Filtrar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow border-0">
        <div class="card-body p-0">
            @if (buscando)
            {
                <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
            }
            else if (pagos == null || !pagos.Any())
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-receipt display-1 opacity-25"></i>
                    <p class="mt-3">@(pagos == null ? "Ajusta los filtros para buscar." : "No se encontraron pagos en este periodo.")</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Folio</th>
                                <th>Fecha</th>
                                <th>Alumno</th>
                                <th>Conceptos Pagados</th>
                                <th class="text-end">Monto</th>
                                <th>Método</th>
                                <th class="text-center border-start border-end bg-light">CFDI / Factura</th>
                                <th class="text-center pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in pagos)
                            {
                                <tr class="@(p.Cancelado ? "table-danger text-muted" : "")">
                                    <td class="ps-4 fw-bold @(p.Cancelado ? "text-danger text-decoration-line-through" : "text-primary")">
                                        #@p.Folio.ToString("00000")
                                        @if (p.Cancelado)
                                        {
                                            <br /><span class="badge bg-danger small">CANCELADO</span>
                                        }
                                    </td>
                                    <td>
                                        @p.FechaPago.ToShortDateString()<br />
                                        <small class="@(p.Cancelado ? "" : "text-muted")">@p.FechaPago.ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        <span class="fw-bold">@p.AlumnoNombre</span><br />
                                        <small class="@(p.Cancelado ? "" : "text-muted")">@p.Matricula</small>
                                    </td>
                                    <td>
                                        <small class="fw-bold d-block text-truncate" style="max-width: 200px;" title="@p.Conceptos">
                                            @p.Conceptos
                                        </small>
                                    </td>
                                    <td class="text-end fw-bold @(p.Cancelado ? "" : "text-success")">
                                        $@p.TotalPagado.ToString("N2")
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@p.MetodoPago</span><br />
                                        <small style="font-size: 0.7em;"><i class="bi bi-person"></i> @p.Usuario</small>
                                    </td>

                                    <td class="text-center border-start border-end bg-light">
                                        @if (p.Cancelado)
                                        {
                                            @if (p.Timbrado)
                                            {
                                                <span class="badge bg-danger border border-danger">CFDI Cancelado</span>

                                                <br />
                                                <small class="text-muted d-inline-block text-truncate" style="font-size: 0.65em; max-width: 100px;" title="@p.Uuid">@p.Uuid</small>
                                            }
                                            else
                                            {
                                                <span class="text-muted">-</span>
                                            }
                                        }
                                        else
                                        {
                                            @if (p.Timbrado)
                                            {
                                                <div class="d-flex flex-column align-items-center">
                                                    <span class="badge bg-success bg-opacity-10 text-success border border-success mb-1"><i class="bi bi-check-circle-fill"></i> Timbrada</span>
                                                    <small class="text-muted d-inline-block text-truncate" style="font-size: 0.65em; max-width: 100px;" title="@p.Uuid">@p.Uuid</small>
                                                    <div class="btn-group mt-1">
                                                        <button class="btn btn-sm btn-outline-primary" @onclick="() => DescargarXmlFactura(p.Id)" title="XML CFDI"><i class="bi bi-filetype-xml"></i></button>
                                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DescargarPdfFactura(p.Id)" title="PDF CFDI"><i class="bi bi-file-pdf"></i></button>
                                                    </div>
                                                </div>
                                            }
                                            else if (p.TieneFacturaBorrador)
                                            {
                                                <button class="btn btn-sm btn-warning fw-bold shadow-sm" @onclick="() => TimbrarBorrador(p.Id)">
                                                    <i class="bi bi-cloud-upload"></i> Timbrar Pendiente
                                                </button>
                                            }
                                            else
                                            {
                                                <button class="btn btn-sm btn-outline-secondary fw-bold shadow-sm"
                                                        @onclick="() => AbrirModalFacturacion(p)"
                                                        disabled="@(!p.PuedeFacturarse)"
                                                        title="@(p.PuedeFacturarse ? "Generar Factura" : "El pago no contiene conceptos facturables")">
                                                    <i class="bi bi-receipt"></i> Facturar
                                                </button>
                                            }
                                        }
                                    </td>
                                    <td class="text-center pe-4 text-nowrap">
                                        <button class="btn btn-sm btn-danger shadow-sm fw-bold me-1" @onclick="() => ImprimirRecibo(p.Id)" title="Ver Recibo Interno">
                                            <i class="bi bi-printer-fill"></i>
                                        </button>

                                        <button class="btn btn-sm btn-info text-white shadow-sm fw-bold me-1" title="Enviar recibo por correo" disabled="@p.Cancelado">
                                            <i class="bi bi-envelope-fill"></i>
                                        </button>

                                        <AuthorizeView Roles="GlobalAdmin, SchoolAdmin">
                                            <Authorized>
                                                @if (!p.Cancelado)
                                                {
                                                    <button class="btn btn-sm btn-outline-dark shadow-sm fw-bold" @onclick="() => CancelarRecibo(p.Id, p.Folio, p.Timbrado)" title="Anular Recibo / CFDI">
                                                        <i class="bi bi-x-circle-fill"></i>
                                                    </button>
                                                }
                                            </Authorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@if (mostrarModalFactura && pagoAFacturar != null)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.6)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-receipt"></i> Generar CFDI - Folio #@pagoAFacturar.Folio.ToString("00000")</h5>
                    <button class="btn-close btn-close-white" @onclick="CerrarModalFacturacion"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-info small">
                        <strong>Alumno:</strong> @pagoAFacturar.AlumnoNombre<br/>
                        <strong>Monto a facturar:</strong> $@pagoAFacturar.TotalPagado.ToString("N2")
                    </div>
                    
                    <label class="fw-bold mb-2">Selecciona el Tutor para facturar:</label>
                    
                    @if (cargandoTutores)
                    {
                        <div class="text-center py-3"><div class="spinner-border spinner-border-sm text-primary"></div></div>
                    }
                    else if (tutores != null && tutores.Any())
                    {
                        <select class="form-select border-primary" @bind="tutorSeleccionadoId">
                            <option value="">-- Selecciona a quién facturar --</option>
                            @foreach (var t in tutores)
                            {
                                <option value="@t.Id">@t.Nombre @t.PrimerApellido - RFC: @(string.IsNullOrEmpty(t.RFC) ? "SIN RFC" : t.RFC)</option>
                            }
                        </select>
                    }
                    else
                    {
                        <div class="alert alert-warning small">Este alumno no tiene tutores registrados con RFC.</div>
                    }
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary fw-bold" @onclick="CerrarModalFacturacion" disabled="@timbrando">Cancelar</button>
                    <button class="btn btn-primary fw-bold" @onclick="TimbrarFactura" disabled="@(string.IsNullOrEmpty(tutorSeleccionadoId?.ToString()) || timbrando)">
                        @if (timbrando)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span> <span>Timbrando en el SAT...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-cloud-upload-fill"></i> Timbrar Factura</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    DateTime fechaInicio = DateTime.Today.AddDays(-7);
    DateTime fechaFin = DateTime.Today;
    string textoBusqueda = "";

    List<Plantel>? planteles;
    List<NivelEducativo>? niveles;
    List<Grado>? grados;
    List<Grupo>? grupos;
    List<CicloEscolar>? ciclos;

    Guid? plantelId;
    Guid? nivelId;
    int? gradoId;
    int? grupoId;
    int cicloFiltroId = 0;

    List<HistorialPagoDto>? pagos;
    bool buscando = false;

    // Variables para Modal de Facturación
    bool mostrarModalFactura = false;
    bool cargandoTutores = false;
    bool timbrando = false;
    HistorialPagoDto? pagoAFacturar;
    List<Tutor>? tutores;
    Guid? tutorSeleccionadoId;

    protected override async Task OnInitializedAsync()
    {
        planteles = await Http.GetFromJsonAsync<List<Plantel>>("api/Planteles");
        ciclos = await Http.GetFromJsonAsync<List<CicloEscolar>>("api/Ciclos");

        var cicloActivo = ciclos?.FirstOrDefault(c => c.Actual);
        if (cicloActivo != null) cicloFiltroId = cicloActivo.Id;

        await BuscarPagos();
    }

    async Task CargarNiveles() { /* Se mantiene igual */ }
    async Task CargarGrados() { /* Se mantiene igual */ }
    async Task CargarGrupos() { /* Se mantiene igual */ }

    async Task BuscarPagos()
    {
        buscando = true;
        pagos = null;
        try
        {
            var url = $"api/Caja/historial?fechaInicio={fechaInicio:yyyy-MM-dd}&fechaFin={fechaFin:yyyy-MM-dd}";
            // ... agregas los filtros igual que lo tenías
            if (!string.IsNullOrWhiteSpace(textoBusqueda)) url += $"&busqueda={Uri.EscapeDataString(textoBusqueda)}";
            pagos = await Http.GetFromJsonAsync<List<HistorialPagoDto>>(url);
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}"); }
        finally { buscando = false; }
    }

    async Task EnterBuscar(KeyboardEventArgs e) { if (e.Key == "Enter") await BuscarPagos(); }

    async Task ImprimirRecibo(Guid pagoId)
    {
        var urlPdf = $"{Http.BaseAddress}api/Reportes/recibo/{pagoId}";
        await JS.InvokeVoidAsync("open", urlPdf, "_blank");
    }

    async Task DescargarXmlFactura(Guid pagoId)
    {
        // Esto abrirá la pestaña nueva con el XML formateado por el navegador
        var urlXml = $"{Http.BaseAddress}api/Facturas/xml/{pagoId}";
        await JS.InvokeVoidAsync("window.open", urlXml, "_blank");
    }

    async Task DescargarPdfFactura(Guid pagoId)
    {
        var urlPdf = $"{Http.BaseAddress}api/Facturas/pdf/{pagoId}";
        await JS.InvokeVoidAsync("open", urlPdf, "_blank");
    }

    // Lógica para abrir el Modal y cargar tutores
    async Task AbrirModalFacturacion(HistorialPagoDto pago)
    {
        pagoAFacturar = pago;
        mostrarModalFactura = true;
        cargandoTutores = true;
        tutorSeleccionadoId = null;
        tutores = null;

        try
        {
            // Usamos el endpoint que ya tienes para la caja
            var respuestaTutores = await Http.GetFromJsonAsync<List<Tutor>>($"api/Caja/tutores/{pago.AlumnoId}");
            tutores = respuestaTutores ?? new List<Tutor>();

            var tutorConRFC = tutores.FirstOrDefault(t => !string.IsNullOrWhiteSpace(t.RFC));
            if (tutorConRFC != null) tutorSeleccionadoId = tutorConRFC.Id;
        }
        catch { await JS.InvokeVoidAsync("alert", "Error al cargar tutores."); }
        finally { cargandoTutores = false; }
    }

    void CerrarModalFacturacion()
    {
        mostrarModalFactura = false;
        pagoAFacturar = null;
    }

    async Task TimbrarFactura()
    {
        if (pagoAFacturar == null || tutorSeleccionadoId == null) return;

        timbrando = true;
        try
        {
            var dto = new { PagoId = pagoAFacturar.Id, TutorId = tutorSeleccionadoId };
            var response = await Http.PostAsJsonAsync("api/Facturas/timbrar-existente", dto);

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "✅ ¡CFDI Timbrado exitosamente en el SAT!");
                CerrarModalFacturacion();
                await BuscarPagos(); // Refrescamos para que salga el UUID
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"❌ Error del PAC: {error}");
            }
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}"); }
        finally { timbrando = false; }
    }

    async Task CancelarRecibo(Guid pagoId, int folio, bool estaTimbrado)
    {
        string mensaje = estaTimbrado 
            ? $"⚠️ ATENCIÓN: El Folio #{folio} ya tiene factura.\n\nAl continuar, se anulará el pago en el sistema Y SE ENVIARÁ LA PETICIÓN AL SAT PARA CANCELAR EL CFDI.\n\nIngresa el MOTIVO de cancelación:" 
            : $"⚠️ Vas a cancelar el Folio #{folio} (Interno).\n\nIngresa el MOTIVO de la cancelación:";

        var motivo = await JS.InvokeAsync<string>("prompt", mensaje);

        if (string.IsNullOrWhiteSpace(motivo)) return;

        try
        {
            // Apuntamos al endpoint que manejará la anulación completa (Sistema + SAT)
            var dto = new { PagoId = pagoId, Motivo = motivo };
            var response = await Http.PostAsJsonAsync("api/Caja/cancelar", dto);

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", $"✅ El recibo #{folio} ha sido cancelado correctamente.");
                await BuscarPagos();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"❌ Error al cancelar: {error}");
            }
        }
        catch (Exception ex) { await JS.InvokeVoidAsync("alert", $"Error de conexión: {ex.Message}"); }
    }

    async Task TimbrarBorrador(Guid pagoId)
    {
        try
        {
            var response = await Http.PostAsync($"api/Facturas/timbrar-borrador/{pagoId}", null);

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "✅ ¡Borrador timbrado exitosamente en el SAT!");
                await BuscarPagos(); // Refrescamos la tabla para que salga el botón verde y el PDF
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", $"❌ Error del PAC: {error}");
            }
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error: {ex.Message}");
        }
    }
}