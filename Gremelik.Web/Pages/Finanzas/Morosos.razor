@page "/finanzas/morosos"
@using Gremelik.core.DTOs
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin")]
@inject HttpClient Http

<div class="container-fluid pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-exclamation-triangle-fill text-danger"></i> Cartera Vencida (Morosos)</h3>
        <button class="btn btn-outline-secondary" @onclick="CargarMorosos">
            <i class="bi bi-arrow-clockwise"></i> Actualizar
        </button>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5"><div class="spinner-border text-danger"></div></div>
    }
    else if (morosos == null)
    {
        <div class="alert alert-danger">Error al cargar el reporte de morosidad.</div>
    }
    else
    {
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card shadow-sm border-danger h-100 bg-danger text-white">
                    <div class="card-body text-center">
                        <h6 class="text-uppercase mb-2 opacity-75">Total en Cartera Vencida</h6>
                        <h2 class="mb-0 fw-bold">$@morosos.Sum(m => m.DeudaTotal).ToString("N2")</h2>
                        <small>De @morosos.Count() alumnos con adeudos</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-danger">
            <div class="card-header bg-white fw-bold d-flex justify-content-between align-items-center">
                <span><i class="bi bi-people-fill text-danger"></i> Alumnos con Pagos Atrasados</span>
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-file-earmark-excel"></i> Exportar</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Matrícula</th>
                                <th>Alumno</th>
                                <th class="text-center">Conceptos Vencidos</th>
                                <th>Deuda Más Antigua</th>
                                <th class="text-end text-danger">Deuda Total</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!morosos.Any())
                            {
                                <tr><td colspan="6" class="text-center py-4 text-success fw-bold">¡Felicidades! No hay alumnos morosos.</td></tr>
                            }
                            else
                            {
                                @foreach (var m in morosos)
                                {
                                    <tr>
                                        <td><span class="badge bg-light text-dark border">@m.Matricula</span></td>
                                        <td class="fw-bold">@m.NombreCompleto</td>
                                        <td class="text-center">
                                            <span class="badge bg-danger rounded-pill">@m.CantidadConceptosVencidos</span>
                                        </td>
                                        <td>
                                            @{
                                                var diasAtraso = (DateTime.Today - m.FechaDeudaMasAntigua).Days;
                                            }
                                            @m.FechaDeudaMasAntigua.ToString("dd/MMM/yyyy")
                                            <small class="text-danger fw-bold d-block">Hace @diasAtraso días</small>
                                        </td>
                                        <td class="text-end fw-bold text-danger fs-5">$@m.DeudaTotal.ToString("N2")</td>
                                        <td class="text-center">
                                            <a href="/finanzas/caja" class="btn btn-sm btn-primary">Ir a Cobrar</a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@code {
    List<AlumnoMorosoDto>? morosos;
    bool cargando = true;

    protected override async Task OnInitializedAsync()
    {
        await CargarMorosos();
    }

    async Task CargarMorosos()
    {
        cargando = true;
        try
        {
            morosos = await Http.GetFromJsonAsync<List<AlumnoMorosoDto>>("api/ReportesFinancieros/morosos");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            morosos = null;
        }
        finally
        {
            cargando = false;
        }
    }
}
