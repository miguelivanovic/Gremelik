@page "/configuracion/oferta"
@using Gremelik.core.Entities
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin")]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid">
    <h3 class="mb-4">📚 Estructura Académica</h3>

    <div class="card mb-4 border-primary">
        <div class="card-body bg-light">
            <label class="fw-bold mb-2">Selecciona el Plantel a configurar:</label>
            @if (planteles == null)
            {
                <p>Cargando planteles...</p>
            }
            else
            {
                <select class="form-select" @onchange="CargarNivelesDelPlantel">
                    <option value="">-- Selecciona un Plantel --</option>
                    @foreach (var p in planteles)
                    {
                        <option value="@p.Id">@p.Nombre (@p.CCT)</option>
                    }
                </select>
            }
        </div>
    </div>

    @if (plantelSeleccionadoId != Guid.Empty)
    {
        <div class="row">
            <div class="col-md-5">
                <div class="card h-100">
                    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                        <span>Niveles Educativos</span>
                        <button class="btn btn-sm btn-light text-dark" @onclick="AbrirModalNivel">+</button>
                    </div>
                    <div class="list-group list-group-flush">
                        @if (niveles == null)
                        {
                            <div class="p-3">Cargando niveles...</div>
                        }
                        else if (!niveles.Any())
                        {
                            <div class="p-3 text-muted">No hay niveles registrados.</div>
                        }
                        else
                        {
                            @foreach (var nivel in niveles)
                            {
                                <button type="button"
                                        class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(nivelSeleccionado?.Id == nivel.Id ? "active" : "")"
                                        @onclick="() => SeleccionarNivel(nivel)">

                                    @nivel.Nombre

                                    @if (nivelSeleccionado?.Id != nivel.Id)
                                    {
                                        <i class="bi bi-chevron-right"></i>
                                    }
                                </button>
                            }
                        }
                    </div>
                </div>
            </div>

            <div class="col-md-7">
                @if (nivelSeleccionado != null)
                {
                    <div class="card h-100 border-secondary">
                        <div class="card-header bg-secondary text-white d-flex justify-content-between align-items-center">
                            <span>Grados de: <strong>@nivelSeleccionado.Nombre</strong></span>
                            <button class="btn btn-sm btn-light text-dark" @onclick="GenerarGradosAutomaticos">
                                <i class="bi bi-magic"></i> Auto-Generar
                            </button>
                        </div>
                        <div class="card-body">
                            @if (grados == null)
                            {
                                <p>Cargando grados...</p>
                            }
                            else if (!grados.Any())
                            {
                                <div class="alert alert-info">
                                    Este nivel no tiene grados aún. <br />
                                    Prueba el botón <strong>Auto-Generar</strong>.
                                </div>
                            }
                            else
                            {
                                <table class="table table-sm">
                                    <thead>
                                        <tr>
                                            <th>#</th>
                                            <th>Nombre Oficial</th>
                                            <th></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var g in grados)
                                        {
                                            <tr>
                                                <td>@g.Numero</td>
                                                <td>@g.Nombre</td>
                                                <td class="text-end">
                                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarGrado(g.Id)">
                                                        <i class="bi bi-x"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }

                            <div class="input-group mt-3">
                                <input type="number" class="form-control" style="max-width: 80px" placeholder="#" @bind="nuevoGradoNumero" />
                                <input type="text" class="form-control" placeholder="Nombre (Ej. 7mo Semestre)" @bind="nuevoGradoNombre" />
                                <button class="btn btn-success" @onclick="AgregarGradoManual">Agregar</button>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="alert alert-secondary h-100 d-flex align-items-center justify-content-center">
                        <div class="text-center text-muted">
                            <i class="bi bi-arrow-left fs-1"></i><br />
                            Selecciona un Nivel para ver sus grados
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

@if (mostrarModalNivel)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Nuevo Nivel Educativo</h5>
                    <button type="button" class="btn-close" @onclick="() => mostrarModalNivel = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label>Nombre (Ej. Primaria, Bachillerato)</label>
                        <input class="form-control" @bind="nuevoNivelNombre" />
                    </div>
                    <div class="mb-3">
                        <label>RVOE (Opcional)</label>
                        <input class="form-control" @bind="nuevoNivelRVOE" />
                    </div>
                    <button class="btn btn-primary w-100" @onclick="GuardarNivel">Guardar</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // Listas
    List<Plantel>? planteles;
    List<NivelEducativo>? niveles;
    List<Grado>? grados;

    // Selecciones
    Guid plantelSeleccionadoId = Guid.Empty;
    NivelEducativo? nivelSeleccionado;

    // Variables de formularios
    bool mostrarModalNivel = false;
    string nuevoNivelNombre = "";
    string nuevoNivelRVOE = "";

    int nuevoGradoNumero = 1;
    string nuevoGradoNombre = "";

    protected override async Task OnInitializedAsync()
    {
        planteles = await Http.GetFromJsonAsync<List<Plantel>>("api/Planteles");
    }

    // 1. Cargar Niveles cuando cambia el select
    private async Task CargarNivelesDelPlantel(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
        {
            plantelSeleccionadoId = id;
            nivelSeleccionado = null; // Reset
            grados = null;
            niveles = await Http.GetFromJsonAsync<List<NivelEducativo>>($"api/Niveles/plantel/{id}");
        }
    }

    // 2. Cargar Grados cuando tocas un nivel
    private async Task SeleccionarNivel(NivelEducativo nivel)
    {
        nivelSeleccionado = nivel;
        grados = await Http.GetFromJsonAsync<List<Grado>>($"api/Grados/nivel/{nivel.Id}");
    }

    // --- LOGICA DE NIVELES ---
    private void AbrirModalNivel()
    {
        nuevoNivelNombre = "";
        mostrarModalNivel = true;
    }

    private async Task GuardarNivel()
    {
        if (string.IsNullOrWhiteSpace(nuevoNivelNombre)) return;

        var nuevo = new NivelEducativo
            {
                Nombre = nuevoNivelNombre,
                RVOE = nuevoNivelRVOE,
                PlantelId = plantelSeleccionadoId,
                Orden = (niveles?.Count ?? 0) + 1 // Lo ponemos al final
            };

        var res = await Http.PostAsJsonAsync("api/Niveles", nuevo);
        if (res.IsSuccessStatusCode)
        {
            mostrarModalNivel = false;
            // Recargar lista
            niveles = await Http.GetFromJsonAsync<List<NivelEducativo>>($"api/Niveles/plantel/{plantelSeleccionadoId}");
        }
    }

    // --- LOGICA DE GRADOS ---
    private async Task AgregarGradoManual()
    {
        if (nivelSeleccionado == null) return;

        var grado = new Grado
            {
                Nombre = nuevoGradoNombre,
                Numero = nuevoGradoNumero,
                NivelEducativoId = (Guid)nivelSeleccionado.Id // Casting explícito si Id es objeto, o directo si es Guid
            };

        await Http.PostAsJsonAsync("api/Grados", grado);
        await SeleccionarNivel(nivelSeleccionado); // Recargar

        // Preparar siguiente
        nuevoGradoNumero++;
        nuevoGradoNombre = "";
    }

    private async Task GenerarGradosAutomaticos()
    {
        if (nivelSeleccionado == null) return;

        // Preguntar cuántos grados (simple prompt JS)
        string input = await JS.InvokeAsync<string>("prompt", "¿Cuántos grados tiene este nivel? (Ej: 6 para Primaria)", "3");

        if (int.TryParse(input, out int total) && total > 0)
        {
            var lote = new List<Grado>();
            for (int i = 1; i <= total; i++)
            {
                lote.Add(new Grado
                    {
                        Nombre = $"{i}º Grado",
                        Numero = i,
                        NivelEducativoId = (Guid)nivelSeleccionado.Id
                    });
            }

            await Http.PostAsJsonAsync("api/Grados/lote", lote);
            await SeleccionarNivel(nivelSeleccionado);
        }
    }

    private async Task EliminarGrado(int id)
    {
        if (await JS.InvokeAsync<bool>("confirm", "Seguro?"))
        {
            await Http.DeleteAsync($"api/Grados/{id}");
            await SeleccionarNivel(nivelSeleccionado!);
        }
    }
}
