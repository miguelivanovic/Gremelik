@page "/configuracion/planteles"
@using Gremelik.core.Entities
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin, Coordinador")]
@inject HttpClient Http

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3>🏢 Mis Planteles</h3>
    <button class="btn btn-primary" @onclick="AbrirModal">
        <i class="bi bi-plus-circle"></i> Nuevo Plantel
    </button>
</div>

@if (planteles == null)
{
    <p><em>Cargando infraestructura...</em></p>
}
else if (!planteles.Any())
{
    <div class="alert alert-warning">
        ⚠️ Esta escuela no tiene planteles registrados. ¡Registra la Matriz ahora!
    </div>
}
else
{
    <div class="row">
        @foreach (var p in planteles)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100 border-start border-5 @(p.EsMatriz ? "border-success" : "border-primary") shadow-sm">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title fw-bold">@p.Nombre</h5>
                            @if (p.EsMatriz)
                            {
                                <span class="badge bg-success">MATRIZ</span>
                            }
                        </div>

                        <p class="card-text text-muted small mb-2">
                            <i class="bi bi-geo-alt-fill"></i> @p.Calle #@p.Numero, @p.Colonia, @p.Municipio, @p.Estado.
                        </p>

                        <hr />

                        <div class="row text-secondary small">
                            <div class="col-6">
                                <strong>CCT:</strong> @(string.IsNullOrEmpty(p.CCT) ? "N/A" : p.CCT)<br />
                                <strong class="text-primary">Razón Social:</strong> @(string.IsNullOrEmpty(p.RazonSocial) ? "N/A" : p.RazonSocial)
                            </div>
                            <div class="col-6">
                                <strong class="text-primary">RFC:</strong> @(string.IsNullOrEmpty(p.RFC) ? "N/A" : p.RFC)<br />
                                <strong class="text-primary">Régimen:</strong> @(string.IsNullOrEmpty(p.RegimenFiscal) ? "N/A" : p.RegimenFiscal) | <strong>CP Fiscal:</strong> @p.CodigoPostalFiscal
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-white text-end border-0">
                        <button class="btn btn-sm btn-outline-primary" @onclick="() => Editar(p)">Editar</button>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(p.Id)">Eliminar</button>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (mostrarFormulario)
{
    <div class="modal d-block" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Registrar Nuevo Plantel</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarFormulario = false"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@nuevoPlantel" OnSubmit="GuardarPlantel">
                        <DataAnnotationsValidator />

                        <div class="row mb-3">
                            <div class="col-md-8">
                                <label>Nombre del Plantel (Ej. Campus Norte)</label>
                                <InputText class="form-control" @bind-Value="nuevoPlantel.Nombre" placeholder="Nombre comercial" />
                            </div>
                            <div class="col-md-4">
                                <label>Estado (Entidad Federativa)</label>
                                <InputText class="form-control" @bind-Value="nuevoPlantel.Estado" placeholder="Ej. Durango" />
                            </div>
                        </div>

                        <h6 class="text-primary mt-4 border-bottom pb-2">📍 Ubicación Física</h6>
                        <div class="row mb-2">
                            <div class="col-md-6"><label>Calle</label><InputText class="form-control" @bind-Value="nuevoPlantel.Calle" /></div>
                            <div class="col-md-2"><label>Número</label><InputText class="form-control" @bind-Value="nuevoPlantel.Numero" /></div>
                            <div class="col-md-4"><label>Colonia</label><InputText class="form-control" @bind-Value="nuevoPlantel.Colonia" /></div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6"><label>Municipio</label><InputText class="form-control" @bind-Value="nuevoPlantel.Municipio" /></div>
                            <div class="col-md-6"><label>Código Postal</label><InputText class="form-control" @bind-Value="nuevoPlantel.CodigoPostal" /></div>
                        </div>

                        <h6 class="text-primary mt-4 border-bottom pb-2">🏛️ Datos Oficiales y Fiscales (CFDI 4.0)</h6>
                        <div class="row mb-3">
                            <div class="col-md-3"><label>CCT (SEP)</label><InputText class="form-control" @bind-Value="nuevoPlantel.CCT" /></div>
                            <div class="col-md-3"><label>RFC (Fiscal)</label><InputText class="form-control" @bind-Value="nuevoPlantel.RFC" /></div>
                            <div class="col-md-6"><label>Razón Social</label><InputText class="form-control" @bind-Value="nuevoPlantel.RazonSocial" /></div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label>Código Postal Fiscal</label>
                                <InputText class="form-control" @bind-Value="nuevoPlantel.CodigoPostalFiscal" />
                            </div>
                            <div class="col-md-8">
                                <label>Régimen Fiscal</label>
                                <InputSelect class="form-select" @bind-Value="nuevoPlantel.RegimenFiscal">
                                    <option value="">-- Selecciona un Régimen --</option>
                                    <option value="601">601 - General de Ley Personas Morales</option>
                                    <option value="603">603 - Personas Morales con Fines no Lucrativos</option>
                                    <option value="612">612 - Personas Físicas con Actividades Empresariales y Profesionales</option>
                                    <option value="626">626 - Régimen Simplificado de Confianza (RESICO)</option>
                                </InputSelect>
                            </div>
                        </div>

                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <button type="button" class="btn btn-secondary" @onclick="() => mostrarFormulario = false">Cancelar</button>
                            <button type="submit" class="btn btn-success">Guardar Plantel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<Plantel>? planteles;
    private Plantel nuevoPlantel = new();
    private bool mostrarFormulario = false;

    protected override async Task OnInitializedAsync()
    {
        await CargarPlanteles();
    }

    private async Task CargarPlanteles()
    {
        planteles = await Http.GetFromJsonAsync<List<Plantel>>("api/Planteles");
    }

    private void AbrirModal()
    {
        nuevoPlantel = new() { Activo = true, Estado = "Durango" }; // Valor por defecto
        mostrarFormulario = true;
    }

    private async Task Eliminar(Guid id)
    {
        // Cambiamos el texto para reflejar el borrado lógico
        if (await JSRuntime.InvokeAsync<bool>("confirm", "¿Estás seguro de dar de baja este plantel? Sus datos históricos se conservarán."))
        {
            await Http.DeleteAsync($"api/Planteles/{id}");
            await CargarPlanteles();
        }
    }

    private void Editar(Plantel p)
    {
        // Clonamos los datos para que si el usuario cancela, no se modifique la tarjeta visualmente
        nuevoPlantel = new Plantel
            {
                Id = p.Id,
                Nombre = p.Nombre,
                Estado = p.Estado,
                Calle = p.Calle,
                Numero = p.Numero,
                Colonia = p.Colonia,
                Municipio = p.Municipio,
                CodigoPostal = p.CodigoPostal,
                CCT = p.CCT,
                RFC = p.RFC,
                RazonSocial = p.RazonSocial,
                CodigoPostalFiscal = p.CodigoPostalFiscal,
                RegimenFiscal = p.RegimenFiscal,
                EsMatriz = p.EsMatriz,
                Activo = p.Activo,
                EscuelaId = p.EscuelaId
            };
        mostrarFormulario = true;
    }

    private async Task GuardarPlantel()
    {
        HttpResponseMessage response;

        // Si el ID está vacío, es uno nuevo (POST). Si ya tiene ID, es una actualización (PUT)
        if (nuevoPlantel.Id == Guid.Empty)
        {
            response = await Http.PostAsJsonAsync("api/Planteles", nuevoPlantel);
        }
        else
        {
            response = await Http.PutAsJsonAsync($"api/Planteles/{nuevoPlantel.Id}", nuevoPlantel);
        }

        if (response.IsSuccessStatusCode)
        {
            mostrarFormulario = false;
            await CargarPlanteles();
        }
        else
        {
            Console.WriteLine("Error al guardar el plantel");
        }
    }

    [Inject] IJSRuntime JSRuntime { get; set; } = default!;
}