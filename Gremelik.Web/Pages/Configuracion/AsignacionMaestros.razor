@page "/configuracion/asignaciones"
@using Gremelik.core.Entities
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin, Coordinador")]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-person-video3 text-primary"></i> Asignación de Maestros a Grupos</h3>
        <button class="btn btn-primary fw-bold shadow-sm" @onclick="AbrirModalNuevo" disabled="@(cicloSeleccionadoId == 0)">
            <i class="bi bi-plus-lg"></i> Asignar Clase
        </button>
    </div>

    <div class="card shadow-sm border-0 bg-light mb-4">
        <div class="card-body d-flex align-items-center gap-3">
            <label class="fw-bold text-muted mb-0">Ciclo Escolar:</label>
            <select class="form-select w-auto border-primary fw-bold" value="@cicloSeleccionadoId" @onchange="CambiarCiclo">
                <option value="0">-- Seleccionar Ciclo --</option>
                @if (ciclos != null)
                {
                    @foreach (var c in ciclos)
                    {
                        <option value="@c.Id">@c.Nombre @(c.Actual ? "(ACTUAL)" : "")</option>
                    }
                }
            </select>

            <label class="fw-bold text-muted mb-0 ms-3">Plantel:</label>
            <select class="form-select w-auto" value="@plantelId" @onchange="CambiarPlantel">
                <option value="">-- Seleccionar --</option>
                @if (planteles != null)
                {
                    @foreach (var p in planteles)
                    {
                        <option value="@p.Id">@p.Nombre</option>
                    }
                }
            </select>
        </div>
    </div>

    @if (cargandoTabla)
    {
        <div class="text-center py-4"><div class="spinner-border text-primary"></div></div>
    }
    else if (cicloSeleccionadoId != 0 && (listaAsignaciones == null || !listaAsignaciones.Any()))
    {
        <div class="alert alert-warning text-center"><i class="bi bi-info-circle"></i> No hay clases asignadas en este ciclo escolar.</div>
    }
    else if (listaAsignaciones != null && listaAsignaciones.Any())
    {
        <div class="card shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Maestro Titular</th>
                        <th>Materia</th>
                        <th>Grupo / Salón</th>
                        <th>Turno</th>
                        <th class="text-end pe-4">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in listaAsignaciones)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-dark"><i class="bi bi-person-badge text-primary me-2"></i>@a.MaestroNombre</td>
                            <td><span class="badge bg-info text-dark">@a.MateriaNombre</span></td>
                            <td class="fw-bold">@a.GrupoNombre</td>
                            <td><small class="text-muted">@a.Turno</small></td>
                            <td class="text-end pe-4">
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => EliminarAsignacion(a.Id, a.MateriaNombre, a.GrupoNombre)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold">Asignar Clase a Maestro</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => mostrarModal = false"></button>
                </div>
                <div class="modal-body bg-light">
                    <EditForm Model="@nuevaAsignacion" OnValidSubmit="GuardarAsignacion">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="fw-bold small text-muted">Selecciona al Maestro *</label>
                            <select class="form-select border-primary" @bind="nuevaAsignacion.MaestroId">
                                <option value="">-- Buscar Maestro --</option>
                                @if (maestros != null)
                                {
                                    @foreach (var m in maestros)
                                    {
                                        <option value="@m.Id">@m.NombreCompleto</option>
                                    }
                                }
                            </select>
                        </div>

                        <hr />

                        <div class="row g-2 mb-3">
                            <div class="col-md-6">
                                <label class="fw-bold small text-muted">Nivel</label>
                                <select class="form-select" @onchange="ModalCambiarNivel" disabled="@(niveles == null)">
                                    <option value="">-- Seleccionar --</option>
                                    @if (niveles != null)
                                    {
                                        @foreach (var n in niveles)
                                        {
                                            <option value="@n.Id">@n.Nombre</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="fw-bold small text-muted">Grado</label>
                                <select class="form-select" value="@gradoTempId" @onchange="ModalCambiarGrado" disabled="@(grados == null)">
                                    <option value="0">-- Seleccionar --</option>
                                    @if (grados != null)
                                    {
                                        @foreach (var g in grados)
                                        {
                                            <option value="@g.Id">@g.Nombre</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="fw-bold small text-muted">Grupo / Salón *</label>
                            <select class="form-select border-primary" value="@nuevaAsignacion.GrupoId" @onchange="ModalCambiarGrupo" disabled="@(grupos == null)">
                                <option value="0">-- Seleccionar --</option>
                                @if (grupos != null)
                                {
                                    @foreach (var g in grupos)
                                    {
                                        <option value="@g.Id">@g.Nombre (@g.Turno)</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="fw-bold small text-muted">Materia a impartir *</label>
                            <select class="form-select border-primary" @bind="nuevaAsignacion.MateriaId" disabled="@(materiasFiltradas == null || !materiasFiltradas.Any())">
                                <option value="">-- Seleccionar Materia --</option>
                                @if (materiasFiltradas != null)
                                {
                                    @foreach (var m in materiasFiltradas)
                                    {
                                        <option value="@m.Id">@m.Nombre</option>
                                    }
                                }
                            </select>
                            @if (materiasFiltradas != null && !materiasFiltradas.Any() && nuevaAsignacion.GrupoId != 0)
                            {
                                <small class="text-danger d-block mt-1">No hay materias configuradas para este grado.</small>
                            }
                        </div>

                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-secondary fw-bold" @onclick="() => mostrarModal = false">Cancelar</button>
                            <button type="submit" class="btn btn-primary fw-bold" disabled="@enviando">
                                @if (enviando)
                                {
                                    <span class="spinner-border spinner-border-sm me-1"></span>
                                }
                                Confirmar Asignación
                            </button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    public class AsignacionVista
    {
        public Guid Id { get; set; }
        public string MaestroNombre { get; set; } = "";
        public string MateriaNombre { get; set; } = "";
        public string GrupoNombre { get; set; } = "";
        public string Turno { get; set; } = "";
    }

    public class MaestroDto
    {
        public string Id { get; set; } = "";
        public string NombreCompleto { get; set; } = "";
    }

    public class MateriaDto
    {
        public Guid Id { get; set; }
        public string Nombre { get; set; } = "";
        public int? GradoId { get; set; }
        public int? GrupoId { get; set; }
    }

    List<CicloEscolar>? ciclos;
    List<Plantel>? planteles;
    int cicloSeleccionadoId = 0;
    Guid plantelId = Guid.Empty;

    List<AsignacionVista>? listaAsignaciones;
    List<MaestroDto>? maestros;
    List<MateriaDto>? todasLasMaterias;
    List<MateriaDto>? materiasFiltradas;

    // Modal Variables
    bool mostrarModal = false;
    bool cargandoTabla = false;
    bool enviando = false;
    AsignacionMaestro nuevaAsignacion = new() { MaestroId = "", Usuario = "" };

    List<NivelEducativo>? niveles;
    List<Grado>? grados;
    List<Grupo>? grupos;
    int gradoTempId = 0;

    protected override async Task OnInitializedAsync()
    {
        ciclos = await Http.GetFromJsonAsync<List<CicloEscolar>>("api/Ciclos");
        planteles = await Http.GetFromJsonAsync<List<Plantel>>("api/Planteles");

        var activo = ciclos?.FirstOrDefault(c => c.Estatus == EstatusCiclo.Actual);
        if (activo != null) cicloSeleccionadoId = activo.Id;

        if (planteles != null && planteles.Count == 1)
        {
            plantelId = planteles.First().Id;
            await CargarDatosBase();
        }
    }

    private async Task CambiarCiclo(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            cicloSeleccionadoId = id;
            if (plantelId != Guid.Empty) await CargarTabla();
        }
    }

    private async Task CambiarPlantel(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
        {
            plantelId = id;
            await CargarDatosBase();
        }
    }

    private async Task CargarDatosBase()
    {
        cargandoTabla = true;
        // Cargamos los maestros de este plantel y las materias disponibles
        maestros = await Http.GetFromJsonAsync<List<MaestroDto>>("api/Asignaciones/maestros");
        todasLasMaterias = await Http.GetFromJsonAsync<List<MateriaDto>>($"api/Materias/plantel/{plantelId}");

        if (cicloSeleccionadoId != 0) await CargarTabla();
        cargandoTabla = false;
    }

    private async Task CargarTabla()
    {
        cargandoTabla = true;
        listaAsignaciones = await Http.GetFromJsonAsync<List<AsignacionVista>>($"api/Asignaciones/ciclo/{cicloSeleccionadoId}");
        cargandoTabla = false;
    }

    private async Task AbrirModalNuevo()
    {
        nuevaAsignacion = new AsignacionMaestro { MaestroId = "", Usuario = "", CicloEscolarId = cicloSeleccionadoId };
        niveles = await Http.GetFromJsonAsync<List<NivelEducativo>>($"api/Niveles/plantel/{plantelId}");
        grados = null; grupos = null; materiasFiltradas = null; gradoTempId = 0;
        mostrarModal = true;
    }

    // --- CASCADAS DEL MODAL ---
    private async Task ModalCambiarNivel(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
            grados = await Http.GetFromJsonAsync<List<Grado>>($"api/Grados/nivel/{id}");
        grupos = null; materiasFiltradas = null; gradoTempId = 0; nuevaAsignacion.GrupoId = 0;
    }

    private async Task ModalCambiarGrado(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id) && id != 0)
        {
            gradoTempId = id;
            grupos = await Http.GetFromJsonAsync<List<Grupo>>($"api/Grupos/grado/{id}/ciclo/{cicloSeleccionadoId}");
        }
        else { grupos = null; gradoTempId = 0; }

        materiasFiltradas = null;
        nuevaAsignacion.GrupoId = 0;
    }

    private void ModalCambiarGrupo(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id) && id != 0)
        {
            nuevaAsignacion.GrupoId = id;
            // MAGIA: Filtramos las materias que aplican a toda la escuela (Grado null),
            // a este grado en particular (GradoId == gradoTempId), o a este grupo exclusivo
            if (todasLasMaterias != null)
            {
                materiasFiltradas = todasLasMaterias.Where(m =>
                    (m.GradoId == null || m.GradoId == gradoTempId) &&
                    (m.GrupoId == null || m.GrupoId == id)
                ).ToList();
            }
        }
        else
        {
            nuevaAsignacion.GrupoId = 0;
            materiasFiltradas = null;
        }
        nuevaAsignacion.MateriaId = Guid.Empty;
    }

    // --- CRUD ---
    private async Task GuardarAsignacion()
    {
        if (string.IsNullOrEmpty(nuevaAsignacion.MaestroId) || nuevaAsignacion.GrupoId == 0 || nuevaAsignacion.MateriaId == Guid.Empty)
        {
            await JS.InvokeVoidAsync("alert", "Completa todos los campos marcados con *"); return;
        }

        enviando = true;
        var res = await Http.PostAsJsonAsync("api/Asignaciones", nuevaAsignacion);
        enviando = false;

        if (res.IsSuccessStatusCode)
        {
            mostrarModal = false;
            await CargarTabla();
        }
        else
        {
            var msg = await res.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", "Error: " + msg);
        }
    }

    private async Task EliminarAsignacion(Guid id, string materia, string grupo)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"¿Quitar al maestro de la clase de {materia} ({grupo})?"))
        {
            var res = await Http.DeleteAsync($"api/Asignaciones/{id}");
            if (res.IsSuccessStatusCode) await CargarTabla();
        }
    }
}
