@page "/academico/observaciones"
@using Microsoft.AspNetCore.Authorization
@using Gremelik.core.Entities
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin, Coordinador, Maestro")]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid pb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3><i class="bi bi-chat-square-text text-primary"></i> Observaciones de Clase</h3>
    </div>

    <div class="card shadow-sm border-0 bg-light mb-4">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="fw-bold text-muted small">Selecciona tu Clase:</label>
                    <select class="form-select border-primary fw-bold" @onchange="SeleccionarClase">
                        <option value="">-- Mis Clases --</option>
                        @if (misClases != null)
                        {
                            @foreach (var c in misClases)
                            {
                                <option value="@c.GrupoId|@c.MateriaId">@c.MateriaNombre - Grupo @c.GrupoNombre</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else if (listaAlumnos != null)
    {
        if (!listaAlumnos.Any())
        {
            <div class="alert alert-warning text-center"><i class="bi bi-info-circle"></i> No hay alumnos inscritos en este grupo.</div>
        }
        else
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white fw-bold">
                    Alumnos Inscritos (@listaAlumnos.Count)
                </div>
                <table class="table table-hover align-middle mb-0">
                    <tbody>
                        @foreach (var alumno in listaAlumnos)
                        {
                            <tr>
                                <td class="ps-4" style="width: 30%;">
                                    <div class="fw-bold text-dark fs-6">@alumno.NombreCompleto</div>
                                    <small class="text-muted">@alumno.Matricula</small>
                                </td>
                                <td class="pe-4">
                                    <textarea class="form-control" rows="2" placeholder="Escribe notas, reportes o felicitaciones..." @bind="alumno.Notas"></textarea>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="card-footer bg-light text-end p-3">
                    <button class="btn btn-primary fw-bold px-4 py-2 shadow-sm" @onclick="GuardarObservaciones" disabled="@enviando">
                        @if (enviando)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                        }
                        <i class="bi bi-save"></i> Guardar Observaciones
                    </button>
                </div>
            </div>
        }
    }
    else if (grupoSeleccionadoId == 0)
    {
        <div class="text-center text-muted mt-5 pt-5">
            <i class="bi bi-arrow-up-circle fs-1"></i>
            <h5 class="mt-3">Selecciona una clase arriba para comenzar</h5>
        </div>
    }
</div>

@code {
    public class ClaseVista
    {
        public Guid MateriaId { get; set; }
        public string MateriaNombre { get; set; } = "";
        public int GrupoId { get; set; }
        public string GrupoNombre { get; set; } = "";
    }

    public class AlumnoObservacion
    {
        public Guid AlumnoId { get; set; }
        public string NombreCompleto { get; set; } = "";
        public string Matricula { get; set; } = "";
        public string Notas { get; set; } = "";
    }

    List<ClaseVista>? misClases;
    List<AlumnoObservacion>? listaAlumnos;
    int cicloActualId = 0;
    int grupoSeleccionadoId = 0;
    Guid materiaSeleccionadaId = Guid.Empty;

    bool cargando = false;
    bool enviando = false;

    protected override async Task OnInitializedAsync()
    {
        var ciclos = await Http.GetFromJsonAsync<List<CicloEscolar>>("api/Ciclos");
        var activo = ciclos?.FirstOrDefault(c => c.Estatus == EstatusCiclo.Actual);

        if (activo != null)
        {
            cicloActualId = activo.Id;
            misClases = await Http.GetFromJsonAsync<List<ClaseVista>>($"api/Asistencias/mis-clases/{cicloActualId}");
        }
    }

    private async Task SeleccionarClase(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString();
        if (!string.IsNullOrEmpty(valor) && valor.Contains("|"))
        {
            var partes = valor.Split('|');
            grupoSeleccionadoId = int.Parse(partes[0]);
            materiaSeleccionadaId = Guid.Parse(partes[1]);

            cargando = true;
            listaAlumnos = await Http.GetFromJsonAsync<List<AlumnoObservacion>>($"api/Observaciones/lista?grupoId={grupoSeleccionadoId}&materiaId={materiaSeleccionadaId}");
            cargando = false;
        }
        else
        {
            grupoSeleccionadoId = 0;
            materiaSeleccionadaId = Guid.Empty;
            listaAlumnos = null;
        }
    }

    private async Task GuardarObservaciones()
    {
        if (listaAlumnos == null || !listaAlumnos.Any()) return;

        enviando = true;

        var dto = new
        {
            GrupoId = grupoSeleccionadoId,
            MateriaId = materiaSeleccionadaId,
            Alumnos = listaAlumnos.Select(a => new { a.AlumnoId, a.Notas }).ToList()
        };

        var res = await Http.PostAsJsonAsync("api/Observaciones/guardar", dto);
        enviando = false;

        if (res.IsSuccessStatusCode)
        {
            await JS.InvokeVoidAsync("alert", "¡Observaciones guardadas correctamente!");
        }
        else
        {
            var msg = await res.Content.ReadAsStringAsync();
            await JS.InvokeVoidAsync("alert", "Error al guardar: " + msg);
        }
    }
}
