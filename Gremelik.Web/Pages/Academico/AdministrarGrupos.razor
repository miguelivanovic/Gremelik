@page "/academico/grupos"
@using Gremelik.core.Entities
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin")]
@inject HttpClient Http
@inject IJSRuntime JS

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>🏫 Gestión de Grupos</h3>
    </div>

    <div class="card mb-4">
        <div class="card-body bg-light d-flex align-items-center gap-3">
            <label class="fw-bold">Ciclo Escolar:</label>
            <select class="form-select w-auto" value="@cicloSeleccionadoId" @onchange="CargarGrupos">
                <option value="0">-- Selecciona --</option>
                @if (ciclos != null)
                {
                    @foreach (var c in ciclos)
                    {
                        <option value="@c.Id">@c.Nombre @(c.Actual ? "(ACTUAL)" : "")</option>
                    }
                }
            </select>

            @if (cicloSeleccionadoId != 0)
            {
                <button class="btn btn-primary ms-auto" @onclick="AbrirModalNuevo">
                    <i class="bi bi-plus-lg"></i> Nuevo Grupo
                </button>
            }
        </div>
    </div>

    @if (cargando)
    {
        <div class="spinner-border text-primary"></div>
    }
    else if (cicloSeleccionadoId != 0 && (listaGrupos == null || !listaGrupos.Any()))
    {
        <div class="alert alert-warning">No hay grupos creados en este ciclo escolar.</div>
    }
    else if (listaGrupos != null)
    {
        <div class="card shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nivel / Grado</th>
                        <th>Nombre Grupo</th>
                        <th>Turno</th>
                        <th>Cupo</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in listaGrupos)
                    {
                        <tr>
                            <td>
                                <small class="text-muted d-block">@g.Grado?.NivelEducativo?.Nombre</small>
                                <strong>@g.Grado?.Nombre</strong>
                            </td>
                            <td class="fs-5 text-primary">@g.Nombre</td>
                            <td>
                                <span class="badge @(g.Turno == "Matutino" ? "bg-warning text-dark" : "bg-dark")">
                                    @g.Turno
                                </span>
                            </td>
                            <td>@g.CupoMaximo</td>
                            <td class="text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => Editar(g)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => Eliminar(g)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (mostrarModal)
{
    <div class="modal fade show d-block" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">@(grupoEdicion.Id == 0 ? "Nuevo Grupo" : "Editar Grupo")</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="CerrarModal"></button>
                </div>
                <div class="modal-body">
                    <EditForm Model="@grupoEdicion" OnValidSubmit="GuardarGrupo">
                        <DataAnnotationsValidator />

                        @if (grupoEdicion.Id == 0)
                        {
                            // Solo mostramos selectores si es NUEVO. Si edita, no puede cambiar de grado/ciclo.
                            <div class="mb-3">
                                <label>Plantel</label>
                                <select class="form-select" @onchange="CargarNiveles">
                                    <option value="">-- Seleccionar --</option>
                                    @if (planteles != null)
                                    {
                                        foreach (var p in planteles)
                                        {
                                            <option value="@p.Id">@p.Nombre</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label>Nivel</label>
                                <select class="form-select" @onchange="CargarGrados" disabled="@(niveles == null)">
                                    <option value="">-- Seleccionar --</option>
                                    @if (niveles != null)
                                    {
                                        foreach (var n in niveles)
                                        {
                                            <option value="@n.Id">@n.Nombre</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="mb-3">
                                <label>Grado *</label>
                                <select class="form-select" @bind="grupoEdicion.GradoId" disabled="@(grados == null)">
                                    <option value="0">-- Seleccionar --</option>
                                    @if (grados != null)
                                    {
                                        foreach (var g in grados)
                                        {
                                            <option value="@g.Id">@g.Nombre</option>
                                        }
                                    }
                                </select>
                            </div>
                        }

                        <div class="mb-3">
                            <label>Nombre del Grupo * (Ej: "A", "B", "Único")</label>
                            <InputText class="form-control" @bind-Value="grupoEdicion.Nombre" />
                        </div>

                        <div class="mb-3">
                            <label>Turno</label>
                            <InputSelect class="form-select" @bind-Value="grupoEdicion.Turno">
                                <option value="Matutino">Matutino</option>
                                <option value="Vespertino">Vespertino</option>
                                <option value="Nocturno">Nocturno</option>
                                <option value="Mixto">Mixto</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label>Cupo Máximo</label>
                            <InputNumber class="form-control" @bind-Value="grupoEdicion.CupoMaximo" />
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="CerrarModal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<CicloEscolar>? ciclos;
    List<Grupo>? listaGrupos;

    // Listas para el formulario
    List<Plantel>? planteles;
    List<NivelEducativo>? niveles;
    List<Grado>? grados;

    int cicloSeleccionadoId = 0;
    bool cargando = false;
    bool mostrarModal = false;

    Grupo grupoEdicion = new() { Usuario = "" }; // Le ponemos un usuario vacío para cumplir

    protected override async Task OnInitializedAsync()
    {
        ciclos = await Http.GetFromJsonAsync<List<CicloEscolar>>("api/Ciclos");
        planteles = await Http.GetFromJsonAsync<List<Plantel>>("api/Planteles");
    }

    private async Task CargarGrupos(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id) && id != 0)
        {
            cicloSeleccionadoId = id;
            cargando = true;
            listaGrupos = await Http.GetFromJsonAsync<List<Grupo>>($"api/Grupos/ciclo/{id}");
            cargando = false;
        }
    }

    // --- LÓGICA DEL MODAL ---

    private void AbrirModalNuevo()
    {
        // Limpiamos el objeto para uno nuevo
        grupoEdicion = new Grupo
            {
                CicloEscolarId = cicloSeleccionadoId,
                CupoMaximo = 30,
                Turno = "Matutino",
                Nombre = "A",
                Usuario = "" // <--- AGREGADO: Obligatorio para compilar
            };
        // Limpiamos listas dependientes
        niveles = null;
        grados = null;

        mostrarModal = true;
    }

    private void Editar(Grupo g)
    {
        // Clonamos el objeto para no editar la tabla en vivo
        grupoEdicion = new Grupo
            {
                Id = g.Id,
                Nombre = g.Nombre,
                Turno = g.Turno,
                CupoMaximo = g.CupoMaximo,
                GradoId = g.GradoId,
                CicloEscolarId = g.CicloEscolarId,
                Usuario = g.Usuario // <--- AGREGADO: Copiamos el usuario original
            };
        mostrarModal = true;
    }

    private void CerrarModal() => mostrarModal = false;

    // --- CASCADAS DEL FORMULARIO ---
    private async Task CargarNiveles(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
            niveles = await Http.GetFromJsonAsync<List<NivelEducativo>>($"api/Niveles/plantel/{id}");
        grados = null;
    }

    private async Task CargarGrados(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id))
            grados = await Http.GetFromJsonAsync<List<Grado>>($"api/Grados/nivel/{id}");
    }

    // --- CRUD ---

    private async Task GuardarGrupo()
    {
        if (grupoEdicion.Id == 0)
        {
            // NUEVO
            if (grupoEdicion.GradoId == 0)
            {
                await JS.InvokeVoidAsync("alert", "Selecciona un Grado"); return;
            }

            var res = await Http.PostAsJsonAsync("api/Grupos", grupoEdicion);
            if (!res.IsSuccessStatusCode)
            {
                var msg = await res.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", "Error: " + msg);
            }
        }
        else
        {
            // EDITAR
            var res = await Http.PutAsJsonAsync($"api/Grupos/{grupoEdicion.Id}", grupoEdicion);
            if (!res.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("alert", "Error al actualizar");
            }
        }

        mostrarModal = false;
        // Recargar tabla
        listaGrupos = await Http.GetFromJsonAsync<List<Grupo>>($"api/Grupos/ciclo/{cicloSeleccionadoId}");
    }

    private async Task Eliminar(Grupo g)
    {
        if (await JS.InvokeAsync<bool>("confirm", $"¿Eliminar grupo {g.Nombre}?"))
        {
            var res = await Http.DeleteAsync($"api/Grupos/{g.Id}");
            if (res.IsSuccessStatusCode)
            {
                listaGrupos = await Http.GetFromJsonAsync<List<Grupo>>($"api/Grupos/ciclo/{cicloSeleccionadoId}");
            }
            else
            {
                var msg = await res.Content.ReadAsStringAsync();
                await JS.InvokeVoidAsync("alert", "No se puede eliminar: " + msg);
            }
        }
    }
}