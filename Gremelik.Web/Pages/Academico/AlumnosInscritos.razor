@page "/academico/listas"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "GlobalAdmin, SchoolAdmin")]
@inject HttpClient Http
@inject IJSRuntime JS

<style>
    /* MAGIA PARA IMPRESIÓN */
    @@media print {
        @@page {
            size: portrait;
            margin: 0mm;
        }

        .ocultar-impresion, .sidebar, .top-row, nav, header, footer {
            display: none !important;
        }

        body, main, .page, .content {
            margin: 0 !important;
            padding: 0 !important;
            background-color: white !important;
        }

        .contenedor-pdf {
            padding: 1.5cm 1cm !important;
        }

        .table-light th {
            background-color: #f8f9fa !important;
            -webkit-print-color-adjust: exact;
        }

        .card {
            border: none !important;
            box-shadow: none !important;
        }

        .card-header {
            display: none !important;
        }
        /* Ocultar el total azul en impresión */

        .solo-impresion {
            display: flex !important;
        }
    }

    .solo-impresion {
        display: none;
    }
</style>

<div class="container-fluid pb-5">
    <div class="ocultar-impresion">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h3>📋 Listas de Grupo</h3>
            <button class="btn btn-outline-dark fw-bold shadow-sm" @onclick="ImprimirLista" disabled="@(resultadoLista == null || !resultadoLista.Alumnos.Any())">
                <i class="bi bi-printer-fill me-2"></i> Imprimir / PDF
            </button>
        </div>

        <div class="card mb-4 shadow-sm border-0 bg-light">
            <div class="card-body py-2">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="small text-muted fw-bold">Ciclo Escolar</label>
                        <select class="form-select border-primary fw-bold" value="@cicloSeleccionadoId" @onchange="CambiarCiclo">
                            @if (ciclos != null)
                            {
                                @foreach (var c in ciclos)
                                {
                                    <option value="@c.Id">@c.Nombre @(c.Actual ? "(ACTUAL)" : "")</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="small text-muted fw-bold">Plantel</label>
                        <select class="form-select border-primary" value="@plantelSeleccionadoId" @onchange="CargarNiveles">
                            <option value="">-- Seleccionar --</option>
                            @if (planteles != null)
                            {
                                foreach (var p in planteles)
                                {
                                    <option value="@p.Id">@p.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="small text-muted fw-bold">Nivel</label>
                        <select class="form-select border-primary" value="@nivelSeleccionadoId" @onchange="CargarGrados" disabled="@(niveles == null)">
                            <option value="">-- --</option>
                            @if (niveles != null)
                            {
                                foreach (var n in niveles)
                                {
                                    <option value="@n.Id">@n.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="small text-muted fw-bold">Grado</label>
                        <select class="form-select border-primary" value="@gradoSeleccionadoId" @onchange="CargarGrupos" disabled="@(grados == null)">
                            <option value="0">-- --</option>
                            @if (grados != null)
                            {
                                foreach (var g in grados)
                                {
                                    <option value="@g.Id">@g.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="small text-muted fw-bold">Grupo</label>
                        <select class="form-select border-primary" value="@grupoSeleccionadoId" @onchange="CargarLista" disabled="@(grupos == null)">
                            <option value="0">-- Ver Todos --</option>
                            @if (grupos != null)
                            {
                                foreach (var gr in grupos)
                                {
                                    <option value="@gr.Id">@gr.Nombre</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @if (cargando)
    {
        <div class="text-center py-5 ocultar-impresion">
            <div class="spinner-border text-primary"></div>
            <p class="mt-2 text-muted fw-bold">Cargando lista oficial...</p>
        </div>
    }
    else if (resultadoLista != null && resultadoLista.Alumnos.Any())
    {
        <div class="contenedor-pdf">

            <div class="solo-impresion justify-content-between align-items-center border-bottom border-dark pb-3 mb-4">
                <div class="d-flex align-items-center">
                    @if (!string.IsNullOrWhiteSpace(resultadoLista.EscuelaLogo))
                    {
                        <img src="@resultadoLista.EscuelaLogo" alt="Logo" style="max-height: 80px; margin-right: 20px;" />
                    }
                    <div>
                        <h2 class="fw-bold mb-0 text-uppercase" style="color: #0b2b5e;">@resultadoLista.EscuelaNombre</h2>
                        <h6 class="text-muted fw-bold">LISTA OFICIAL DE ASISTENCIA</h6>
                    </div>
                </div>
                <div class="text-end">
                    <h6 class="fw-bold text-dark mb-0">@resultadoLista.NivelGradoGrupo</h6>
                    <span class="text-muted fw-bold d-block">Ciclo: @resultadoLista.CicloNombre</span>
                    <span class="small text-muted">Fecha: @DateTime.Now.ToString("dd/MM/yyyy")</span>
                </div>
            </div>

            <div class="card border-dark shadow-sm">
                <div class="card-header bg-white border-bottom border-dark ocultar-impresion">
                    <span class="badge bg-primary">Total: @resultadoLista.Alumnos.Count alumnos</span>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover table-bordered align-middle mb-0 border-dark">
                        <thead class="table-light border-dark">
                            <tr>
                                <th class="text-center" style="width: 50px;">#</th>
                                <th style="width: 120px;">Matrícula</th>
                                <th>Nombre del Alumno (Paterno, Materno, Nombre)</th>
                                <th>Grupo</th>
                                <th class="text-center ocultar-impresion" style="width: 120px;">Expediente</th>
                            </tr>
                        </thead>
                        <tbody class="border-dark">
                            @{
                                int i = 1;
                            }
                            @foreach (var item in resultadoLista.Alumnos)
                            {
                                <tr>
                                    <td class="text-center text-muted fw-bold small">@(i++)</td>
                                    <td class="fw-bold text-secondary">@item.Matricula</td>
                                    <td class="fw-bold text-dark">@item.NombreCompleto</td>
                                    <td>
                                        <span class="badge bg-light text-dark border border-secondary">@item.GrupoNombre</span>
                                    </td>
                                    <td class="text-center ocultar-impresion">
                                        <a href="/academico/expediente-360/@item.AlumnoId" class="btn btn-sm btn-primary shadow-sm" title="Ver Expediente 360">
                                            <i class="bi bi-person-lines-fill"></i> 360
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (gradoSeleccionadoId != 0)
    {
        <div class="alert alert-info text-center mt-3 ocultar-impresion shadow-sm">
            <i class="bi bi-info-circle"></i> No hay alumnos inscritos con estos filtros.
        </div>
    }
</div>

@code {
    // --- CLASES DTO ---
    public class ListaImpresionDto
    {
        public string EscuelaNombre { get; set; } = "";
        public string EscuelaLogo { get; set; } = "";
        public string CicloNombre { get; set; } = "";
        public string NivelGradoGrupo { get; set; } = "";
        public List<AlumnoFilaDto> Alumnos { get; set; } = new();
    }

    public class AlumnoFilaDto
    {
        public Guid AlumnoId { get; set; }
        public string Matricula { get; set; } = "";
        public string NombreCompleto { get; set; } = "";
        public string GrupoNombre { get; set; } = "";
    }

    public class CicloEscolarBasico { public int Id { get; set; } public bool Actual { get; set; } public string Nombre { get; set; } = ""; }
    public class PlantelBasico { public Guid Id { get; set; } public string Nombre { get; set; } = ""; }
    public class NivelBasico { public Guid Id { get; set; } public string Nombre { get; set; } = ""; }
    public class GradoBasico { public int Id { get; set; } public string Nombre { get; set; } = ""; } // Ahora sí, el grado usa Int
    public class GrupoBasico { public int Id { get; set; } public string Nombre { get; set; } = ""; }

    // --- VARIABLES ---
    List<CicloEscolarBasico>? ciclos;
    List<PlantelBasico>? planteles;
    List<NivelBasico>? niveles;
    List<GradoBasico>? grados;
    List<GrupoBasico>? grupos;

    ListaImpresionDto? resultadoLista;

    // Control de selecciones
    int cicloSeleccionadoId = 0;
    Guid plantelSeleccionadoId = Guid.Empty;
    Guid nivelSeleccionadoId = Guid.Empty;
    int gradoSeleccionadoId = 0;
    int grupoSeleccionadoId = 0;
    bool cargando = false;

    protected override async Task OnInitializedAsync()
    {
        planteles = await Http.GetFromJsonAsync<List<PlantelBasico>>("api/Planteles");
        ciclos = await Http.GetFromJsonAsync<List<CicloEscolarBasico>>("api/Ciclos");

        if (ciclos != null)
        {
            var actual = ciclos.FirstOrDefault(c => c.Actual);
            if (actual != null) cicloSeleccionadoId = actual.Id;
            else if (ciclos.Any()) cicloSeleccionadoId = ciclos.First().Id;
        }
    }

    // --- MÉTODOS DE CASCADA (CON LIMPIEZA) ---
    private async Task CambiarCiclo(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id))
        {
            cicloSeleccionadoId = id;
            // Si ya hay un grado seleccionado, recargamos los grupos porque son de otro ciclo
            if (gradoSeleccionadoId != 0)
            {
                grupos = await Http.GetFromJsonAsync<List<GrupoBasico>>($"api/Grupos/grado/{gradoSeleccionadoId}/ciclo/{cicloSeleccionadoId}");
                grupoSeleccionadoId = 0;
                await EjecutarConsulta();
            }
        }
    }

    private async Task CargarNiveles(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id) && id != Guid.Empty)
        {
            plantelSeleccionadoId = id;
            niveles = await Http.GetFromJsonAsync<List<NivelBasico>>($"api/Niveles/plantel/{id}");
        }
        else
        {
            plantelSeleccionadoId = Guid.Empty;
            niveles = null;
        }

        // Limpieza de hijos
        nivelSeleccionadoId = Guid.Empty;
        grados = null; gradoSeleccionadoId = 0;
        grupos = null; grupoSeleccionadoId = 0;
        resultadoLista = null;
    }

    private async Task CargarGrados(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out Guid id) && id != Guid.Empty)
        {
            nivelSeleccionadoId = id;
            grados = await Http.GetFromJsonAsync<List<GradoBasico>>($"api/Grados/nivel/{id}");
        }
        else
        {
            nivelSeleccionadoId = Guid.Empty;
            grados = null;
        }

        // Limpieza de hijos
        gradoSeleccionadoId = 0;
        grupos = null; grupoSeleccionadoId = 0;
        resultadoLista = null;
    }

    private async Task CargarGrupos(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int id) && id != 0)
        {
            gradoSeleccionadoId = id;
            grupos = await Http.GetFromJsonAsync<List<GrupoBasico>>($"api/Grupos/grado/{id}/ciclo/{cicloSeleccionadoId}");
            grupoSeleccionadoId = 0;
            await EjecutarConsulta();
        }
        else
        {
            gradoSeleccionadoId = 0;
            grupos = null; grupoSeleccionadoId = 0;
            resultadoLista = null;
        }
    }

    private async Task CargarLista(ChangeEventArgs? e)
    {
        if (e != null && int.TryParse(e.Value?.ToString(), out int id))
        {
            grupoSeleccionadoId = id;
        }
        await EjecutarConsulta();
    }

    private async Task EjecutarConsulta()
    {
        cargando = true;
        string url = $"api/Inscripciones/lista?cicloId={cicloSeleccionadoId}&gradoId={gradoSeleccionadoId}";
        if (grupoSeleccionadoId != 0) url += $"&grupoId={grupoSeleccionadoId}";

        try
        {
            resultadoLista = await Http.GetFromJsonAsync<ListaImpresionDto>(url);
        }
        catch
        {
            resultadoLista = new ListaImpresionDto();
        }
        cargando = false;
    }

    private async Task ImprimirLista()
    {
        await JS.InvokeVoidAsync("window.print");
    }
}